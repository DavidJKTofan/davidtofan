# Custom headers for static assets
# https://developers.cloudflare.com/workers/static-assets/headers/
#
# Note: All pages are prerendered as static HTML, so all headers are set here.
#
# Early Hints: Cloudflare automatically caches and sends 103 Early Hints
# based on Link headers in origin responses. Enable in Cloudflare Dashboard:
# Speed > Optimization > Content Optimization > Early Hints
# https://developers.cloudflare.com/cache/advanced-configuration/early-hints/

# Prevent workers.dev preview URLs from being indexed by search engines
https://davidtofan-astro.cf-testing.workers.dev/*
  X-Robots-Tag: noindex

# Security headers for all HTML pages
/*.html
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin

/
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin

/articles/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin

/projects/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin

/certificates
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin

# Astro optimized/fingerprinted assets (hashed filenames) - cache for 1 year
# These files have content hashes in their names, so they can be cached indefinitely
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# All static assets at root level (favicons, manifest, etc.) - cache for 10 hours
/*.png
  Cache-Control: public, max-age=36000
  X-Content-Type-Options: nosniff

/*.jpg
  Cache-Control: public, max-age=36000
  X-Content-Type-Options: nosniff

/*.svg
  Cache-Control: public, max-age=36000
  X-Content-Type-Options: nosniff

/*.ico
  Cache-Control: public, max-age=36000
  X-Content-Type-Options: nosniff

/*.webp
  Cache-Control: public, max-age=36000
  X-Content-Type-Options: nosniff

# Web manifest
/*.webmanifest
  Cache-Control: public, max-age=36000
  X-Content-Type-Options: nosniff

# Web fonts (if added in future) - cache for 1 year
/*.woff
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff
