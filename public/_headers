# Custom headers for static assets
# https://developers.cloudflare.com/workers/static-assets/headers/
#
# Note: All pages are prerendered as static HTML, so all headers are set here.
#
# Early Hints: Cloudflare automatically caches and sends 103 Early Hints
# based on Link headers in origin responses. Enable in Cloudflare Dashboard:
# Speed > Optimization > Content Optimization > Early Hints
# https://developers.cloudflare.com/cache/advanced-configuration/early-hints/

# AI agent discovery — RFC 8288 Link headers
# rel="describedby" / "license" per RFC 9727 §3 + Cloudflare ai-crawl-control guide.
# /ai-licensing-terms/ is the real target page (src/pages/ai-licensing-terms.astro).

# Security + agent-discovery headers for all HTML pages
/*.html
  Link: </ai-licensing-terms/>; rel="describedby"; type="text/html", </ai-licensing-terms/>; rel="license"; type="text/html", </rsl.xml>; rel="license"; type="application/rsl+xml", </sitemap-index.xml>; rel="sitemap"
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin

/
  Link: </ai-licensing-terms/>; rel="describedby"; type="text/html", </ai-licensing-terms/>; rel="license"; type="text/html", </rsl.xml>; rel="license"; type="application/rsl+xml", </sitemap-index.xml>; rel="sitemap"
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin

/articles/*
  Link: </ai-licensing-terms/>; rel="describedby"; type="text/html", </ai-licensing-terms/>; rel="license"; type="text/html", </rsl.xml>; rel="license"; type="application/rsl+xml", </sitemap-index.xml>; rel="sitemap"
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin

/projects/*
  Link: </ai-licensing-terms/>; rel="describedby"; type="text/html", </ai-licensing-terms/>; rel="license"; type="text/html", </rsl.xml>; rel="license"; type="application/rsl+xml", </sitemap-index.xml>; rel="sitemap"
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin

/certificates/
  Link: </ai-licensing-terms/>; rel="describedby"; type="text/html", </ai-licensing-terms/>; rel="license"; type="text/html", </rsl.xml>; rel="license"; type="application/rsl+xml", </sitemap-index.xml>; rel="sitemap"
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin

/ai-licensing-terms/
  Link: </ai-licensing-terms/>; rel="describedby"; type="text/html", </ai-licensing-terms/>; rel="license"; type="text/html", </rsl.xml>; rel="license"; type="application/rsl+xml", </sitemap-index.xml>; rel="sitemap"
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  X-Robots-Tag: noindex

/welcome
  X-Robots-Tag: noindex
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# robots.txt — force UTF-8 so Content Signals render correctly (em dashes etc.)
/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=36000

# RSL 1.0 machine-readable license document — https://rslstandard.org/rsl
/rsl.xml
  # Use a browser-native XML media type so the document renders instead of downloading.
  Content-Type: application/xml; charset=utf-8
  Content-Disposition: inline
  Cache-Control: public, max-age=36000
  X-Content-Type-Options: nosniff

# Astro optimized/fingerprinted assets (hashed filenames) - cache for 1 year
# These files have content hashes in their names, so they can be cached indefinitely
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# All static assets at root level (favicons, manifest, etc.) - cache for 10 hours
/*.png
  Content-Type: image/png
  Cache-Control: public, max-age=36000
  X-Content-Type-Options: nosniff

/*.jpg
  Content-Type: image/jpeg
  Cache-Control: public, max-age=36000
  X-Content-Type-Options: nosniff

/*.jpeg
  Content-Type: image/jpeg
  Cache-Control: public, max-age=36000
  X-Content-Type-Options: nosniff

/*.svg
  Content-Type: image/svg+xml
  Cache-Control: public, max-age=36000
  X-Content-Type-Options: nosniff

/*.ico
  Content-Type: image/x-icon
  Cache-Control: public, max-age=36000
  X-Content-Type-Options: nosniff

/*.webp
  Content-Type: image/webp
  Cache-Control: public, max-age=36000
  X-Content-Type-Options: nosniff

# Web manifest
/*.webmanifest
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=36000
  X-Content-Type-Options: nosniff

# Web fonts (if added in future) - cache for 1 year
/*.woff
  Content-Type: font/woff
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/*.woff2
  Content-Type: font/woff2
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# Images in subdirectories (articles, projects, img)
/articles/*/*.png
  Content-Type: image/png
  Cache-Control: public, max-age=36000
  X-Content-Type-Options: nosniff

/projects/*/*.png
  Content-Type: image/png
  Cache-Control: public, max-age=36000
  X-Content-Type-Options: nosniff

/img/*.png
  Content-Type: image/png
  Cache-Control: public, max-age=36000
  X-Content-Type-Options: nosniff

/img/*.webp
  Content-Type: image/webp
  Cache-Control: public, max-age=36000
  X-Content-Type-Options: nosniff

/img/*/*.webp
  Content-Type: image/webp
  Cache-Control: public, max-age=36000
  X-Content-Type-Options: nosniff
