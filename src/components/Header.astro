---
import { navigation, siteConfig } from '../config/site';

const currentPath = Astro.url.pathname;
const aiSearchConfig = siteConfig.aiSearch?.enabled ? siteConfig.aiSearch : null;
const aiSearchSnippetURL = aiSearchConfig
  ? new URL(`/assets/${aiSearchConfig.snippetVersion}/search-snippet.es.js`, aiSearchConfig.apiUrl).toString()
  : null;
---

<header class="fixed top-0 left-0 right-0 z-40">
  <div class="glass border-b border-surface-200/50 dark:border-surface-800/50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 md:h-18">
        <!-- Logo -->
        <a
          href="/"
          class="inline-flex min-h-11 cursor-pointer select-none items-center gap-3 rounded-xl px-1.5 group"
          aria-label="DT — Home"
        >
          <div class="relative w-9 h-9 rounded-full bg-gradient-to-br from-accent-400 to-accent-600 flex items-center justify-center shadow-lg shadow-accent-500/25 group-hover:shadow-accent-500/40 transition-shadow duration-300">
            <span class="pointer-events-none text-white font-display font-bold text-sm">DT</span>
          </div>
          <span class="pointer-events-none hidden sm:block font-display font-bold text-lg text-surface-900 dark:text-surface-50 group-hover:text-accent-600 dark:group-hover:text-accent-400 transition-colors duration-200">
            {siteConfig.name}
          </span>
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
          {navigation.map((item) => {
            const isActive = currentPath === item.href || 
              (item.href !== '/' && currentPath.startsWith(item.href));
            return (
              <a
                href={item.href}
                class:list={[
                  'inline-flex min-h-11 cursor-pointer select-none items-center rounded-lg px-4 py-2 text-sm font-medium transition-all duration-200',
                  isActive
                    ? 'text-accent-600 dark:text-accent-400 bg-accent-50 dark:bg-accent-900/20'
                    : 'text-surface-600 dark:text-surface-400 hover:text-surface-900 dark:hover:text-surface-100 hover:bg-surface-100 dark:hover:bg-surface-800',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                {item.label}
              </a>
            );
          })}
        </nav>

        <!-- Right side actions -->
        <div class="flex items-center gap-2">
          {aiSearchConfig && (
            <button
              id="search-modal-trigger"
              type="button"
              class="inline-flex h-11 w-11 cursor-pointer select-none items-center justify-center rounded-lg text-surface-500 dark:text-surface-400 hover:text-surface-700 dark:hover:text-surface-200 hover:bg-surface-100 dark:hover:bg-surface-800 transition-colors duration-200"
              aria-label="Search David Tofan's site"
              aria-haspopup="dialog"
              title="Search David Tofan's site (Cmd/Ctrl+K)"
              data-search-snippet-url={aiSearchSnippetURL}
            >
              <svg
                class="pointer-events-none block w-5 h-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <circle cx="11" cy="11" r="7" />
                <path d="M20 20l-3.5-3.5" />
              </svg>
            </button>
          )}

          <!-- Theme toggle -->
          <button
            id="theme-toggle"
            type="button"
            class="inline-flex h-11 w-11 cursor-pointer select-none items-center justify-center rounded-lg text-surface-500 dark:text-surface-400 hover:text-surface-700 dark:hover:text-surface-200 hover:bg-surface-100 dark:hover:bg-surface-800 transition-colors duration-200"
            aria-label="Switch to dark theme"
            aria-pressed="false"
          >
            <!-- Sun icon (shown in dark mode) -->
            <svg
              class="pointer-events-none hidden w-5 h-5 dark:block"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="5" />
              <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
            </svg>
            <!-- Moon icon (shown in light mode) -->
            <svg
              class="pointer-events-none block w-5 h-5 dark:hidden"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
          </button>

          <!-- Mobile menu button -->
          <button
            id="mobile-menu-toggle"
            type="button"
            class="md:hidden inline-flex h-11 w-11 cursor-pointer select-none items-center justify-center rounded-lg text-surface-500 dark:text-surface-400 hover:text-surface-700 dark:hover:text-surface-200 hover:bg-surface-100 dark:hover:bg-surface-800 transition-colors duration-200"
            aria-label="Toggle menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <svg class="pointer-events-none w-5 h-5 menu-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg class="pointer-events-none w-5 h-5 hidden close-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden absolute top-full left-0 right-0 glass border-b border-surface-200/50 dark:border-surface-800/50"
  >
    <nav class="max-w-6xl mx-auto px-4 py-4 space-y-1" aria-label="Mobile navigation">
      {navigation.map((item) => {
        const isActive = currentPath === item.href || 
          (item.href !== '/' && currentPath.startsWith(item.href));
        return (
          <a
            href={item.href}
            class:list={[
              'block cursor-pointer select-none rounded-lg px-4 py-3 text-base font-medium transition-all duration-200',
              isActive
                ? 'text-accent-600 dark:text-accent-400 bg-accent-50 dark:bg-accent-900/20'
                : 'text-surface-600 dark:text-surface-400 hover:text-surface-900 dark:hover:text-surface-100 hover:bg-surface-100 dark:hover:bg-surface-800',
            ]}
            aria-current={isActive ? 'page' : undefined}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>

{aiSearchConfig && (
  <search-modal-snippet
    id="site-search-modal"
    api-url={aiSearchConfig.apiUrl}
    placeholder={aiSearchConfig.placeholder}
    shortcut={aiSearchConfig.shortcut}
    max-results={aiSearchConfig.maxResults ? String(aiSearchConfig.maxResults) : undefined}
    show-url={aiSearchConfig.showUrl ? 'true' : undefined}
    show-date={aiSearchConfig.showDate ? 'true' : undefined}
    hide-branding={String(aiSearchConfig.hideBranding ?? false)}
    theme="light"
  ></search-modal-snippet>
)}

<script>
  function setupMobileMenu() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const menuIcon = toggle?.querySelector('.menu-icon');
    const closeIcon = toggle?.querySelector('.close-icon');

    if (!(toggle instanceof HTMLButtonElement) || !(menu instanceof HTMLElement) || !menuIcon || !closeIcon) return;
    if (toggle.dataset.mobileMenuBound === 'true') return;

    const appWindow = window as Window & { mobileMenuAbortController?: AbortController };
    appWindow.mobileMenuAbortController?.abort();
    const controller = new AbortController();
    appWindow.mobileMenuAbortController = controller;

    toggle.dataset.mobileMenuBound = 'true';

    function closeMenu() {
      toggle.setAttribute('aria-expanded', 'false');
      menu.classList.add('hidden');
      menuIcon.classList.remove('hidden');
      closeIcon.classList.add('hidden');
    }

    function toggleMenu() {
      const isExpanded = toggle.getAttribute('aria-expanded') === 'true';

      if (isExpanded) {
        closeMenu();
        return;
      }

      toggle.setAttribute('aria-expanded', 'true');
      menu.classList.remove('hidden');
      menuIcon.classList.add('hidden');
      closeIcon.classList.remove('hidden');
    }

    toggle.addEventListener('click', toggleMenu, { signal: controller.signal });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
        closeMenu();
        toggle.focus();
      }
    }, { signal: controller.signal });

    document.addEventListener('click', (event) => {
      if (toggle.getAttribute('aria-expanded') !== 'true') return;
      if (!(event.target instanceof Node)) return;
      if (menu.contains(event.target) || toggle.contains(event.target)) return;

      closeMenu();
    }, { signal: controller.signal });

    // Close menu when clicking a link
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu, { signal: controller.signal });
    });
  }

  function initMobileMenu() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupMobileMenu, { once: true });
    } else {
      setupMobileMenu();
    }
  }

  function syncSearchModalTheme() {
    const modal = document.getElementById('site-search-modal');
    if (!(modal instanceof HTMLElement)) return;

    const theme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
    modal.setAttribute('theme', theme);
  }

  async function loadSearchSnippet(trigger: HTMLButtonElement) {
    const appWindow = window as Window & { aiSearchSnippetPromise?: Promise<void> };
    const snippetUrl = trigger.dataset.searchSnippetUrl;

    if (!snippetUrl || customElements.get('search-modal-snippet')) return;

    if (!appWindow.aiSearchSnippetPromise) {
      appWindow.aiSearchSnippetPromise = new Promise<void>((resolve, reject) => {
        const existingScript = document.querySelector<HTMLScriptElement>('script[data-ai-search-snippet]');

        if (existingScript) {
          existingScript.addEventListener('load', () => resolve(), { once: true });
          existingScript.addEventListener('error', () => reject(new Error('AI search snippet failed to load')), { once: true });
          return;
        }

        const script = document.createElement('script');
        script.type = 'module';
        script.src = snippetUrl;
        script.dataset.aiSearchSnippet = 'true';
        script.addEventListener('load', () => resolve(), { once: true });
        script.addEventListener('error', () => reject(new Error('AI search snippet failed to load')), { once: true });
        document.head.append(script);
      }).then(async () => {
        if (typeof customElements !== 'undefined') {
          await customElements.whenDefined('search-modal-snippet');
        }
      });
    }

    await appWindow.aiSearchSnippetPromise;
  }

  async function openSearchModal() {
    const trigger = document.getElementById('search-modal-trigger');
    const modal = document.getElementById('site-search-modal');

    if (!(trigger instanceof HTMLButtonElement) || !(modal instanceof HTMLElement)) return;

    try {
      await loadSearchSnippet(trigger);
      syncSearchModalTheme();

      const searchModal = modal as HTMLElement & { open?: () => void };
      searchModal.open?.();
    } catch (error) {
      console.error(error);
    }
  }

  function setupSearchModal() {
    const trigger = document.getElementById('search-modal-trigger');
    const modal = document.getElementById('site-search-modal');

    syncSearchModalTheme();

    if (!(trigger instanceof HTMLButtonElement) || !(modal instanceof HTMLElement)) return;
    if (trigger.dataset.searchModalBound === 'true') return;

    trigger.dataset.searchModalBound = 'true';

    trigger.addEventListener('click', openSearchModal);
  }

  function bindSearchShortcut() {
    if (document.documentElement.dataset.searchShortcutBound === 'true') return;

    document.documentElement.dataset.searchShortcutBound = 'true';
    document.addEventListener('keydown', (event) => {
      if (!(event instanceof KeyboardEvent)) return;
      if (event.key.toLowerCase() !== 'k' || (!event.metaKey && !event.ctrlKey)) return;

      event.preventDefault();
      openSearchModal();
    });
  }

  function initHeaderActions() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        setupMobileMenu();
        setupSearchModal();
        bindSearchShortcut();
      }, { once: true });
    } else {
      setupMobileMenu();
      setupSearchModal();
      bindSearchShortcut();
    }
  }

  function bindHeaderActionsPageLoad() {
    if (document.documentElement.dataset.headerActionsPageLoadBound === 'true') return;

    document.documentElement.dataset.headerActionsPageLoadBound = 'true';
    document.addEventListener('astro:page-load', () => {
      setupMobileMenu();
      setupSearchModal();
    });
  }

  bindHeaderActionsPageLoad();
  initHeaderActions();
</script>
