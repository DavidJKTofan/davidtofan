---
interface Props {
  number: string;
  id: string;
  eyebrow?: string;
  title: string;
  lede?: string;
}

const { number, id, eyebrow, title, lede } = Astro.props;
---

<section id={id} class="walk-section scroll-mt-28 py-12 md:py-16 first:pt-0">
  <header class="mb-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-accent-600/10 text-accent-600 dark:text-accent-400 font-mono text-sm font-semibold ring-1 ring-accent-500/20">
        {number}
      </span>
      {eyebrow && (
        <span class="text-xs font-semibold text-accent-600 dark:text-accent-400 uppercase tracking-[0.14em]">
          {eyebrow}
        </span>
      )}
    </div>
    <h2 class="font-display font-bold text-2xl sm:text-3xl md:text-4xl text-surface-900 dark:text-surface-50 leading-tight tracking-tight mb-3 text-balance">
      {title}
    </h2>
    {lede && (
      <p class="text-base sm:text-lg text-surface-600 dark:text-surface-400 leading-relaxed max-w-2xl" set:html={lede}></p>
    )}
  </header>
  <slot />
</section>

<style>
  .walk-section {
    border-top: 1px solid transparent;
  }
  .walk-section + .walk-section {
    border-top-color: rgb(231 229 228 / 0.6);
  }
  :global(.dark) .walk-section + .walk-section {
    border-top-color: rgb(41 37 36 / 0.6);
  }
</style>
