---
// Crawl-to-refer ratio chart — logarithmic-feeling bar visualization
const platforms = [
  { name: 'Anthropic', ratio: 38065, color: 'red', logo: 'A' },
  { name: 'OpenAI', ratio: 1091, color: 'emerald', logo: 'O' },
  { name: 'Perplexity', ratio: 195, color: 'violet', logo: 'P' },
  { name: 'Microsoft', ratio: 41, color: 'sky', logo: 'M' },
  { name: 'Yandex', ratio: 21, color: 'rose', logo: 'Y' },
  { name: 'Google', ratio: 5.4, color: 'amber', logo: 'G' },
  { name: 'ByteDance', ratio: 0.9, color: 'cyan', logo: 'B' },
  { name: 'Mistral', ratio: 0.1, color: 'indigo', logo: 'M' },
];

const maxLog = Math.log10(platforms[0].ratio + 1);
const rows = platforms.map((p) => {
  const w = Math.max(2, (Math.log10(p.ratio + 1) / maxLog) * 100);
  return { ...p, width: w };
});
---

<div class="my-8 rounded-2xl border border-surface-200 dark:border-surface-800 bg-surface-50/50 dark:bg-surface-950/60 overflow-hidden">
  <div class="flex items-center justify-between gap-4 px-5 py-3 border-b border-surface-200 dark:border-surface-800 bg-surface-100/60 dark:bg-surface-900/60">
    <span class="text-xs font-mono uppercase tracking-wider text-surface-600 dark:text-surface-400">
      Crawl-to-refer ratio · July 2025
    </span>
    <span class="text-2xs font-mono text-surface-600 dark:text-surface-400">log scale · lower = better</span>
  </div>

  <div class="p-5 sm:p-7 space-y-2.5">
    {rows.map((p, i) => (
      <div
        class="crawl-row grid grid-cols-[6.5rem_1fr_5.5rem] sm:grid-cols-[7.5rem_1fr_6rem] items-center gap-3"
        style={`--i: ${i}`}
      >
        <div class="text-sm font-semibold text-surface-800 dark:text-surface-100 truncate">
          {p.name}
        </div>
        <div class="relative h-3 rounded-full bg-surface-200/60 dark:bg-surface-800/80 overflow-hidden">
          <div
            class="crawl-bar absolute inset-y-0 left-0 rounded-full"
            style={`--bar-width: ${p.width}%`}
          ></div>
        </div>
        <div class="text-right font-mono text-xs sm:text-sm text-surface-600 dark:text-surface-300 tabular-nums">
          <span class="font-semibold">{p.ratio.toLocaleString()}</span>:1
        </div>
      </div>
    ))}
  </div>

  <div class="px-5 py-3 border-t border-surface-200 dark:border-surface-800 bg-surface-50 dark:bg-surface-900/40">
    <p class="text-xs text-surface-600 dark:text-surface-400 leading-relaxed">
      Read: for every single visitor Anthropic's crawler refers back, it has read ~38,000 pages.
      <br>Live data on
      <a href="https://radar.cloudflare.com/ai-insights#crawl-to-refer-ratio" target="_blank" rel="noopener noreferrer" class="underline decoration-dotted hover:text-accent-600 dark:hover:text-accent-400">Cloudflare Radar — AI Insights</a>.
    </p>
  </div>
</div>

<style>
  .crawl-row { opacity: 0; transform: translateX(-8px); animation: crawlIn 0.45s ease-out forwards; animation-delay: calc(var(--i) * 0.055s); }
  @keyframes crawlIn { to { opacity: 1; transform: translateX(0); } }
  .crawl-bar {
    width: 0;
    background: linear-gradient(90deg, rgb(59 130 246 / 0.65), rgb(239 68 68 / 0.85));
    animation: barGrow 0.9s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
    animation-delay: calc(var(--i) * 0.055s + 0.15s);
  }
  @keyframes barGrow { to { width: var(--bar-width); } }
</style>
