---
// HTTP 402 / Pay Per Crawl — swimlane sequence diagram
---

<div class="my-8 rounded-2xl border border-accent-500/40 dark:border-accent-500/30 bg-surface-50/50 dark:bg-surface-950/60 overflow-hidden shadow-lg shadow-accent-500/5">
  <div class="flex items-center justify-between gap-4 px-5 py-3 border-b border-surface-200 dark:border-surface-800 bg-gradient-to-r from-accent-500/10 to-transparent">
    <div class="flex items-center gap-2 min-w-0">
      <span class="ppc-dot flex-shrink-0"></span>
      <span class="text-xs font-mono uppercase tracking-wider font-bold text-accent-700 dark:text-accent-300 truncate">
        HTTP 402 · Pay Per Crawl handshake
      </span>
    </div>
    <a
      href="https://developers.cloudflare.com/ai-crawl-control/features/pay-per-crawl/what-is-pay-per-crawl/"
      target="_blank"
      rel="noopener noreferrer"
      class="text-2xs font-mono text-accent-600 dark:text-accent-400 hover:underline flex-shrink-0"
    >docs →</a>
  </div>

  <div class="p-5 sm:p-6">
    <!-- Lanes header -->
    <div class="ppc-lanes grid grid-cols-4 gap-2 mb-4 text-2xs font-mono uppercase tracking-wider">
      <div class="text-center py-2 rounded-md bg-surface-100/70 dark:bg-surface-900/60 border border-surface-200 dark:border-surface-800 text-surface-600 dark:text-surface-400 truncate">Crawler</div>
      <div class="text-center py-2 rounded-md bg-accent-500/10 border border-accent-500/30 text-accent-700 dark:text-accent-400 truncate">CF Edge</div>
      <div class="text-center py-2 rounded-md bg-surface-100/70 dark:bg-surface-900/60 border border-surface-200 dark:border-surface-800 text-surface-600 dark:text-surface-400 truncate">Publisher</div>
      <div class="text-center py-2 rounded-md bg-emerald-500/10 border border-emerald-500/30 text-emerald-700 dark:text-emerald-400 truncate">Settlement</div>
    </div>

    <ol class="space-y-2.5">
      <!-- Step 1: Crawler → CF Edge -->
      <li class="ppc-step" style="--i: 0">
        <div class="ppc-row grid grid-cols-4 gap-2 items-stretch">
          <div class="ppc-card ppc-card-origin" data-lane="Crawler">
            <div class="flex items-center gap-1.5 mb-1">
              <span class="w-5 h-5 rounded-full bg-surface-200 dark:bg-surface-800 text-surface-700 dark:text-surface-300 flex items-center justify-center font-mono text-2xs font-semibold">1</span>
              <span class="text-2xs font-mono uppercase tracking-wider text-surface-600 dark:text-surface-400">Request</span>
            </div>
            <pre class="text-2xs font-mono text-surface-700 dark:text-surface-300 m-0 overflow-x-auto"><code>GET /article
<span class="text-accent-600 dark:text-accent-400">Signature: :MEUCIQD...</span></code></pre>
          </div>
          <div class="ppc-arrow ppc-arrow-right"><span class="ppc-packet ppc-packet-right"></span></div>
          <div class="ppc-card ppc-card-dim ppc-card-empty"></div>
          <div class="ppc-card ppc-card-dim ppc-card-empty"></div>
        </div>
      </li>

      <!-- Step 2: CF Edge → Crawler: 402 -->
      <li class="ppc-step" style="--i: 1">
        <div class="ppc-row grid grid-cols-4 gap-2 items-stretch">
          <div class="ppc-card ppc-card-dim ppc-card-empty"></div>
          <div class="ppc-arrow ppc-arrow-left-amber"><span class="ppc-packet ppc-packet-left ppc-packet-amber"></span></div>
          <div class="ppc-card ppc-card-edge" data-lane="CF Edge">
            <div class="flex items-center gap-1.5 mb-1">
              <span class="w-5 h-5 rounded-full bg-amber-500/20 text-amber-700 dark:text-amber-400 ring-1 ring-amber-500/40 flex items-center justify-center font-mono text-2xs font-semibold">2</span>
              <span class="text-2xs font-mono uppercase tracking-wider text-amber-700 dark:text-amber-400">402</span>
            </div>
            <pre class="text-2xs font-mono text-surface-700 dark:text-surface-300 m-0 overflow-x-auto"><code><span class="text-amber-600 dark:text-amber-400">402 Payment Required</span>
<span class="text-accent-600 dark:text-accent-400">crawler-price:</span> USD 0.05</code></pre>
          </div>
          <div class="ppc-card ppc-card-dim ppc-card-empty"></div>
        </div>
      </li>

      <!-- Step 3: Crawler retries -->
      <li class="ppc-step" style="--i: 2">
        <div class="ppc-row grid grid-cols-4 gap-2 items-stretch">
          <div class="ppc-card ppc-card-origin" data-lane="Crawler">
            <div class="flex items-center gap-1.5 mb-1">
              <span class="w-5 h-5 rounded-full bg-surface-200 dark:bg-surface-800 text-surface-700 dark:text-surface-300 flex items-center justify-center font-mono text-2xs font-semibold">3</span>
              <span class="text-2xs font-mono uppercase tracking-wider text-surface-600 dark:text-surface-400">Retry</span>
            </div>
            <pre class="text-2xs font-mono text-surface-700 dark:text-surface-300 m-0 overflow-x-auto"><code>GET /article
<span class="text-accent-600 dark:text-accent-400">crawler-max-price:
  USD 0.10</span></code></pre>
          </div>
          <div class="ppc-arrow ppc-arrow-right"><span class="ppc-packet ppc-packet-right"></span></div>
          <div class="ppc-card ppc-card-dim ppc-card-empty"></div>
          <div class="ppc-card ppc-card-dim ppc-card-empty"></div>
        </div>
      </li>

      <!-- Step 4: CF Edge → Publisher origin -->
      <li class="ppc-step" style="--i: 3">
        <div class="ppc-row grid grid-cols-4 gap-2 items-stretch">
          <div class="ppc-card ppc-card-dim ppc-card-empty"></div>
          <div class="ppc-card ppc-card-edge" data-lane="CF Edge">
            <div class="flex items-center gap-1.5 mb-1">
              <span class="w-5 h-5 rounded-full bg-accent-500/20 text-accent-700 dark:text-accent-400 ring-1 ring-accent-500/40 flex items-center justify-center font-mono text-2xs font-semibold">4</span>
              <span class="text-2xs font-mono uppercase tracking-wider text-accent-700 dark:text-accent-400">Verify</span>
            </div>
            <div class="text-2xs font-mono text-surface-600 dark:text-surface-400">
              Signature ok<br/>
              Price match
            </div>
          </div>
          <div class="ppc-arrow ppc-arrow-right"><span class="ppc-packet ppc-packet-right"></span></div>
          <div class="ppc-card ppc-card-origin" data-lane="Publisher">
            <div class="text-2xs font-mono uppercase tracking-wider text-surface-600 dark:text-surface-400 mb-1">Fetch</div>
            <div class="text-2xs font-mono text-surface-700 dark:text-surface-300">origin HTML</div>
          </div>
        </div>
      </li>

      <!-- Step 5: Response back to crawler -->
      <li class="ppc-step" style="--i: 4">
        <div class="ppc-row grid grid-cols-4 gap-2 items-stretch">
          <div class="ppc-card ppc-card-dim ppc-card-empty"></div>
          <div class="ppc-arrow ppc-arrow-left-emerald"><span class="ppc-packet ppc-packet-left ppc-packet-emerald"></span></div>
          <div class="ppc-card ppc-card-edge" data-lane="CF Edge">
            <div class="flex items-center gap-1.5 mb-1">
              <span class="w-5 h-5 rounded-full bg-emerald-500/20 text-emerald-700 dark:text-emerald-400 ring-1 ring-emerald-500/40 flex items-center justify-center font-mono text-2xs font-semibold">5</span>
              <span class="text-2xs font-mono uppercase tracking-wider text-emerald-700 dark:text-emerald-400">200</span>
            </div>
            <pre class="text-2xs font-mono text-surface-700 dark:text-surface-300 m-0 overflow-x-auto"><code><span class="text-emerald-600 dark:text-emerald-400">200 OK</span>
<span class="text-emerald-600 dark:text-emerald-400">crawler-charged:</span>
  USD 0.05</code></pre>
          </div>
          <div class="ppc-card ppc-card-dim ppc-card-empty"></div>
        </div>
      </li>

      <!-- Step 6: Settlement recorded -->
      <li class="ppc-step" style="--i: 5">
        <div class="ppc-row grid grid-cols-4 gap-2 items-stretch">
          <div class="ppc-card ppc-card-dim ppc-card-empty"></div>
          <div class="ppc-card ppc-card-edge" data-lane="CF Edge">
            <div class="flex items-center gap-1.5 mb-1">
              <span class="w-5 h-5 rounded-full bg-emerald-500/20 text-emerald-700 dark:text-emerald-400 ring-1 ring-emerald-500/40 flex items-center justify-center font-mono text-2xs font-semibold">6</span>
              <span class="text-2xs font-mono uppercase tracking-wider text-emerald-700 dark:text-emerald-400">Charge</span>
            </div>
            <div class="text-2xs font-mono text-surface-600 dark:text-surface-400">record ledger</div>
          </div>
          <div class="ppc-arrow ppc-arrow-right-emerald"><span class="ppc-packet ppc-packet-right ppc-packet-emerald"></span></div>
          <div class="ppc-card ppc-card-settle" data-lane="Settlement">
            <div class="flex items-center gap-1.5 mb-1">
              <span class="w-5 h-5 rounded-full bg-emerald-500/20 text-emerald-700 dark:text-emerald-400 ring-1 ring-emerald-500/40 flex items-center justify-center font-mono text-2xs font-semibold">✓</span>
              <span class="text-2xs font-mono uppercase tracking-wider text-emerald-700 dark:text-emerald-400">MoR</span>
            </div>
            <div class="text-2xs font-mono text-surface-700 dark:text-surface-300">
              Cloudflare<br/>
              pays publisher
            </div>
          </div>
        </div>
      </li>
    </ol>
  </div>

  <div class="px-5 py-3 border-t border-surface-200 dark:border-surface-800 bg-surface-50 dark:bg-surface-900/40">
    <p class="text-xs text-surface-600 dark:text-surface-400 leading-relaxed">
      The <code>402 Payment Required</code> status has existed since HTTP/1.1 in 1997 — it finally has a use. Cloudflare acts as Merchant of Record; signatures verified via
      <a href="https://blog.cloudflare.com/web-bot-auth/" target="_blank" rel="noopener noreferrer" class="underline decoration-dotted hover:text-accent-600 dark:hover:text-accent-400">Web Bot Auth</a>. <br>In practice, the crawler provider signs these requests and the publisher consumes the verification result.
      This diagram shows the common <strong>402-then-retry</strong> flow: Step 2 returns <code>crawler-price</code>, and Step 3 retries with <code>crawler-max-price</code>. If a crawler already knows the site's policy, it can send <code>crawler-max-price</code> on the first request; after a 402, it can also retry with <code>crawler-exact-price: USD 0.05</code>.
      The open-standard version — <a href="https://x402.org/" target="_blank" rel="noopener noreferrer" class="underline decoration-dotted hover:text-accent-600 dark:hover:text-accent-400">x402</a> — settles on-chain.
    </p>
  </div>
</div>

<style>
  .ppc-dot {
    position: relative;
    display: inline-block;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background-color: rgb(16 185 129);
  }
  .ppc-dot::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 9999px;
    background-color: rgb(16 185 129 / 0.4);
    animation: ppcDotPulse 1.8s ease-out infinite;
  }
  @keyframes ppcDotPulse {
    0% { transform: scale(0.6); opacity: 0.9; }
    100% { transform: scale(2); opacity: 0; }
  }

  .ppc-card {
    padding: 0.625rem 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid rgb(214 211 209);
    background: rgb(250 250 249 / 0.6);
    min-height: 3.75rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  :global(.dark) .ppc-card {
    border-color: rgb(41 37 36);
    background: rgb(28 25 23 / 0.6);
  }
  .ppc-card-edge {
    border-color: rgb(59 130 246 / 0.4);
    background: rgb(59 130 246 / 0.05);
  }
  :global(.dark) .ppc-card-edge {
    border-color: rgb(59 130 246 / 0.3);
    background: rgb(59 130 246 / 0.08);
  }
  .ppc-card-settle {
    border-color: rgb(16 185 129 / 0.4);
    background: rgb(16 185 129 / 0.05);
  }
  :global(.dark) .ppc-card-settle {
    border-color: rgb(16 185 129 / 0.3);
    background: rgb(16 185 129 / 0.08);
  }
  .ppc-card-dim {
    opacity: 0.35;
    background: transparent;
    border-style: dashed;
  }

  .ppc-arrow {
    position: relative;
    min-height: 3.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ppc-arrow::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 8%;
    right: 8%;
    height: 2px;
    transform: translateY(-50%);
  }
  .ppc-arrow-right::after {
    background: linear-gradient(90deg, rgb(59 130 246 / 0.25), rgb(59 130 246 / 0.7));
  }
  .ppc-arrow-right::before {
    content: '▶';
    position: absolute;
    top: 50%;
    right: 6%;
    transform: translateY(-50%);
    color: rgb(59 130 246);
    font-size: 0.625rem;
  }
  .ppc-arrow-left-amber::after {
    background: linear-gradient(270deg, rgb(245 158 11 / 0.25), rgb(245 158 11 / 0.7));
  }
  .ppc-arrow-left-amber::before {
    content: '◀';
    position: absolute;
    top: 50%;
    left: 6%;
    transform: translateY(-50%);
    color: rgb(245 158 11);
    font-size: 0.625rem;
  }
  .ppc-arrow-left-emerald::after {
    background: linear-gradient(270deg, rgb(16 185 129 / 0.25), rgb(16 185 129 / 0.7));
  }
  .ppc-arrow-left-emerald::before {
    content: '◀';
    position: absolute;
    top: 50%;
    left: 6%;
    transform: translateY(-50%);
    color: rgb(16 185 129);
    font-size: 0.625rem;
  }
  .ppc-arrow-right-emerald::after {
    background: linear-gradient(90deg, rgb(16 185 129 / 0.25), rgb(16 185 129 / 0.7));
  }
  .ppc-arrow-right-emerald::before {
    content: '▶';
    position: absolute;
    top: 50%;
    right: 6%;
    transform: translateY(-50%);
    color: rgb(16 185 129);
    font-size: 0.625rem;
  }

  .ppc-step {
    opacity: 0;
    transform: translateY(4px);
    animation: ppcStepIn 0.45s ease-out forwards;
    animation-delay: calc(var(--i) * 0.1s + 0.1s);
  }
  @keyframes ppcStepIn {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Animated packets travelling along arrows */
  .ppc-packet {
    position: absolute;
    top: 50%;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background: rgb(59 130 246);
    box-shadow: 0 0 0 3px rgb(59 130 246 / 0.2), 0 0 10px rgb(59 130 246 / 0.5);
    transform: translateY(-50%);
    opacity: 0;
  }
  .ppc-packet-amber {
    background: rgb(245 158 11);
    box-shadow: 0 0 0 3px rgb(245 158 11 / 0.2), 0 0 10px rgb(245 158 11 / 0.5);
  }
  .ppc-packet-emerald {
    background: rgb(16 185 129);
    box-shadow: 0 0 0 3px rgb(16 185 129 / 0.2), 0 0 10px rgb(16 185 129 / 0.5);
  }
  .ppc-packet-right {
    left: 8%;
    animation: ppcPacketRight 2.4s ease-in-out infinite;
  }
  .ppc-packet-left {
    right: 8%;
    animation: ppcPacketLeft 2.4s ease-in-out infinite;
  }
  @keyframes ppcPacketRight {
    0% { left: 8%; opacity: 0; }
    15% { opacity: 1; }
    85% { opacity: 1; }
    100% { left: 92%; opacity: 0; }
  }
  @keyframes ppcPacketLeft {
    0% { right: 8%; opacity: 0; }
    15% { opacity: 1; }
    85% { opacity: 1; }
    100% { right: 92%; opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ppc-dot::before { animation: none; }
    .ppc-step { animation: none; opacity: 1; transform: none; }
    .ppc-packet { animation: none; opacity: 0; }
  }

  @media (max-width: 640px) {
    .ppc-lanes { display: none; }
    .ppc-row { grid-template-columns: minmax(0, 1fr); }
    .ppc-arrow, .ppc-card-empty { display: none; }
    .ppc-card {
      padding: 0.5rem;
      min-height: auto;
    }
    .ppc-card pre { font-size: 0.625rem; }
    .ppc-card[data-lane]::before {
      content: attr(data-lane);
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.625rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: rgb(120 113 108);
      margin-bottom: 0.375rem;
    }
    :global(.dark) .ppc-card[data-lane]::before {
      color: rgb(168 162 158);
    }
  }
</style>
