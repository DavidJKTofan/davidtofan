---
const bots = [
  { id: 'GPTBot', vendor: 'OpenAI', purpose: 'AI crawler' },
  { id: 'ClaudeBot', vendor: 'Anthropic', purpose: 'AI crawler' },
  { id: 'Google-Extended', vendor: 'Google', purpose: 'training control' },
  { id: 'Applebot-Extended', vendor: 'Apple', purpose: 'training control' },
  { id: 'Bytespider', vendor: 'ByteDance', purpose: 'AI crawler' },
  { id: 'CCBot', vendor: 'Common Crawl', purpose: 'AI crawler' },
  { id: 'meta-externalagent', vendor: 'Meta', purpose: 'AI crawler' },
  { id: 'Amazonbot', vendor: 'Amazon', purpose: 'AI crawler' },
];
---

<div class="robots-builder demo-card relative overflow-hidden rounded-2xl border border-accent-500/40 dark:border-accent-500/30 bg-surface-50/50 dark:bg-surface-950/60 my-8 shadow-lg shadow-accent-500/5" data-robots-builder>
  <!-- Top bar -->
  <div class="flex items-center justify-between gap-3 px-5 py-3 border-b border-surface-200 dark:border-surface-800 bg-gradient-to-r from-accent-500/10 to-transparent">
    <div class="flex items-center gap-2 min-w-0">
      <span class="live-dot flex-shrink-0"></span>
      <span class="text-xs font-mono uppercase tracking-wider font-bold text-accent-700 dark:text-accent-300 truncate">
        Interactive demo · robots.txt builder
      </span>
      <span class="text-2xs text-surface-600 dark:text-surface-400 hidden sm:inline">— click any bot to toggle</span>
    </div>
    <button
      type="button"
      data-preset
      class="preset-btn min-h-10 text-xs font-mono px-3 py-2 rounded-md border border-surface-300 dark:border-surface-700 text-surface-600 dark:text-surface-400 hover:text-accent-600 dark:hover:text-accent-400 hover:border-accent-400 transition-colors"
      aria-label="Toggle training-bot preset"
    >
      Block training bots
    </button>
  </div>

  <div class="grid lg:grid-cols-[minmax(0,1fr)_minmax(0,1.15fr)] gap-0">
    <!-- Left: AI user agent list -->
    <div class="min-w-0 p-5 sm:p-6 border-b lg:border-b-0 lg:border-r border-surface-200 dark:border-surface-800">
      <h3 class="text-xs font-mono uppercase tracking-wider text-surface-600 dark:text-surface-400 mb-1.5">
        Selected AI crawlers
      </h3>
      <p class="text-2xs text-surface-600 dark:text-surface-400 mb-4 leading-relaxed">
        This simplified view focuses on the bots most likely to matter for crawl or training control. Allowed bots do not need explicit entries here; robots.txt only needs the blocks you actually want to emit.
      </p>
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-2" role="list">
        {bots.map((b) => (
          <li>
            <button
              type="button"
              data-bot={b.id}
              data-state="blocked"
              class="bot-toggle group w-full min-w-0 flex items-center justify-between gap-3 px-3.5 py-2.5 rounded-lg border text-left transition-all"
              aria-pressed="true"
            >
              <span class="min-w-0">
                <span class="block font-mono text-sm text-surface-800 dark:text-surface-100 truncate">{b.id}</span>
                <span class="block text-2xs text-surface-600 dark:text-surface-400 mt-0.5">{b.vendor} · {b.purpose}</span>
              </span>
              <span class="bot-badge flex-shrink-0 font-mono text-2xs uppercase tracking-wider px-2 py-1 rounded-md"></span>
            </button>
          </li>
        ))}
      </ul>

      <!-- Content signals -->
      <h3 class="text-xs font-mono uppercase tracking-wider text-surface-600 dark:text-surface-400 mt-6 mb-3">
        Content signals
      </h3>
      <div class="grid grid-cols-3 gap-2">
        {['search', 'ai-input', 'ai-train'].map((s) => (
          <div class="text-center">
            <div class="text-2xs font-mono text-surface-600 dark:text-surface-400 mb-1.5">{s}</div>
            <div class="inline-flex rounded-md border border-surface-300 dark:border-surface-700 overflow-hidden w-full" role="group">
              <button
                type="button"
                data-signal={s}
                data-value="yes"
                class="signal-btn min-h-10 flex-1 px-2.5 py-2 text-2xs font-mono uppercase font-semibold transition-colors"
              >yes</button>
              <button
                type="button"
                data-signal={s}
                data-value="no"
                class="signal-btn min-h-10 flex-1 px-2.5 py-2 text-2xs font-mono uppercase font-semibold transition-colors"
              >no</button>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Right: generated output -->
    <div class="relative min-w-0 flex flex-col">
      <div class="flex items-center justify-between gap-4 px-5 py-3 border-b border-surface-200 dark:border-surface-800 bg-surface-50 dark:bg-surface-900/40">
        <span class="text-xs font-mono uppercase tracking-wider text-surface-600 dark:text-surface-400">
          Output · /robots.txt
        </span>
        <button
          type="button"
          data-copy-robots
          class="min-h-10 text-xs font-mono px-3 py-2 rounded-md border border-surface-300 dark:border-surface-700 text-surface-600 dark:text-surface-400 hover:text-accent-600 dark:hover:text-accent-400 hover:border-accent-400 transition-colors inline-flex items-center gap-1.5"
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <rect x="8" y="8" width="12" height="12" rx="2" />
            <path d="M16 8V6a2 2 0 00-2-2H6a2 2 0 00-2 2v8a2 2 0 002 2h2" />
          </svg>
          <span data-copy-label>Copy</span>
        </button>
      </div>
      <pre class="robots-output flex-1 overflow-auto text-xs sm:text-sm leading-relaxed font-mono p-5 sm:p-6 m-0 bg-transparent"><code data-output></code></pre>
    </div>
  </div>

  <div class="px-5 py-3 border-t border-surface-200 dark:border-surface-800 bg-surface-50 dark:bg-surface-900/40">
    <p class="text-xs text-surface-600 dark:text-surface-400 leading-relaxed">
      Allowed crawlers are implicit — only explicit <code class="px-1 py-0.5 rounded bg-surface-100 dark:bg-surface-800 font-mono text-2xs">Disallow</code> blocks are emitted. <br>Tip: on Cloudflare, flip
      <a href="https://developers.cloudflare.com/bots/additional-configurations/managed-robots-txt/" target="_blank" rel="noopener noreferrer" class="underline decoration-dotted hover:text-accent-600 dark:hover:text-accent-400">Security Settings → Bot traffic → robots.txt</a>
      to auto-generate and maintain this for you.
    </p>
  </div>
</div>

<style>
  /* Live-demo animated dot */
  .live-dot {
    position: relative;
    display: inline-block;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background-color: rgb(16 185 129);
  }
  .live-dot::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 9999px;
    background-color: rgb(16 185 129 / 0.4);
    animation: liveDotPulse 1.8s ease-out infinite;
  }
  @keyframes liveDotPulse {
    0% { transform: scale(0.6); opacity: 0.9; }
    100% { transform: scale(2); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .live-dot::before { animation: none; }
  }

  /* Bot toggle states (data-state driven) */
  .bot-toggle[data-state="blocked"] {
    border-color: rgb(249 115 22 / 0.55);
    background-color: rgb(249 115 22 / 0.06);
  }
  .bot-toggle[data-state="blocked"] .bot-badge {
    background-color: rgb(249 115 22 / 0.14);
    color: rgb(194 65 12);
  }
  :global(.dark) .bot-toggle[data-state="blocked"] .bot-badge {
    color: rgb(253 186 116);
  }
  .bot-toggle[data-state="allowed"] {
    border-color: rgb(231 229 228);
    background-color: transparent;
  }
  :global(.dark) .bot-toggle[data-state="allowed"] {
    border-color: rgb(41 37 36);
  }
  .bot-toggle[data-state="allowed"] .bot-badge {
    background-color: rgb(16 185 129 / 0.12);
    color: rgb(4 120 87);
  }
  :global(.dark) .bot-toggle[data-state="allowed"] .bot-badge {
    color: rgb(110 231 183);
  }
  .bot-toggle:hover {
    transform: translateY(-1px);
  }
  .bot-toggle:focus-visible {
    outline: 2px solid var(--color-accent-500, #3b82f6);
    outline-offset: 2px;
  }

  /* Preset toggle button */
  .preset-btn[data-active="true"] {
    border-color: rgb(249 115 22 / 0.55);
    background-color: rgb(249 115 22 / 0.08);
    color: rgb(194 65 12);
  }
  :global(.dark) .preset-btn[data-active="true"] {
    color: rgb(253 186 116);
  }

  /* Signal buttons */
  .signal-btn {
    background: transparent;
    color: rgb(120 113 108);
  }
  :global(.dark) .signal-btn { color: rgb(168 162 158); }
  .signal-btn[data-active="true"] {
    background-color: rgb(59 130 246 / 0.15);
    color: rgb(29 78 216);
  }
  :global(.dark) .signal-btn[data-active="true"] {
    color: rgb(147 197 253);
  }

  /* Output code highlighting (manual tokens inside JS) */
  .robots-output { color: rgb(87 83 78); }
  :global(.dark) .robots-output { color: rgb(214 211 209); }
  .robots-output :global(.tok-dir) { color: rgb(234 88 12); }
  :global(.dark) .robots-output :global(.tok-dir) { color: rgb(253 186 116); }
  .robots-output :global(.tok-ua) { color: rgb(37 99 235); font-weight: 600; }
  :global(.dark) .robots-output :global(.tok-ua) { color: rgb(96 165 250); }
  .robots-output :global(.tok-com) { color: rgb(168 162 158); font-style: italic; }
  .robots-output :global(.tok-signal) { color: rgb(5 150 105); }
  :global(.dark) .robots-output :global(.tok-signal) { color: rgb(52 211 153); }
</style>

<script>
  type BotState = 'blocked' | 'allowed';
  interface SignalState {
    search: 'yes' | 'no';
    'ai-input': 'yes' | 'no';
    'ai-train': 'yes' | 'no';
  }

  let cleanupRobots: (() => void) | null = null;

  function escapeHtml(s: string): string {
    return s.replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c] as string));
  }

  function renderRobotsOutput(bots: { id: string; state: BotState }[], signals: SignalState): string {
    const lines: string[] = [];
    lines.push('<span class="tok-com"># /robots.txt — generated</span>');
    lines.push('<span class="tok-ua">User-agent:</span> *');
    lines.push(
      `<span class="tok-signal">Content-Signal:</span> search=${signals.search}, ai-input=${signals['ai-input']}, ai-train=${signals['ai-train']}`
    );
    lines.push('<span class="tok-dir">Allow:</span> /');
    lines.push('<span class="tok-dir">Disallow:</span> /cdn-cgi/');
    lines.push('');
    const blocked = bots.filter((b) => b.state === 'blocked');
    for (const b of blocked) {
      lines.push(`<span class="tok-ua">User-agent:</span> ${escapeHtml(b.id)}`);
      lines.push('<span class="tok-dir">Disallow:</span> /');
      lines.push('');
    }
    if (blocked.length === 0) {
      lines.push('<span class="tok-com"># No crawlers explicitly blocked — all allowed by default.</span>');
      lines.push('');
    }
    lines.push('<span class="tok-ua">Sitemap:</span> https://example.com/sitemap.xml');
    return lines.join('\n');
  }

  function plainRobotsOutput(bots: { id: string; state: BotState }[], signals: SignalState): string {
    const lines: string[] = [];
    lines.push('# /robots.txt — generated');
    lines.push('User-agent: *');
    lines.push(`Content-Signal: search=${signals.search}, ai-input=${signals['ai-input']}, ai-train=${signals['ai-train']}`);
    lines.push('Allow: /');
    lines.push('Disallow: /cdn-cgi/');
    lines.push('');
    const blocked = bots.filter((b) => b.state === 'blocked');
    for (const b of blocked) {
      lines.push(`User-agent: ${b.id}`);
      lines.push('Disallow: /');
      lines.push('');
    }
    if (blocked.length === 0) {
      lines.push('# No crawlers explicitly blocked — all allowed by default.');
      lines.push('');
    }
    lines.push('Sitemap: https://example.com/sitemap.xml');
    return lines.join('\n');
  }

  function setupRobotsBuilder() {
    if (cleanupRobots) cleanupRobots();

    const root = document.querySelector<HTMLDivElement>('[data-robots-builder]');
    if (!root) {
      cleanupRobots = null;
      return;
    }

    const output = root.querySelector<HTMLElement>('[data-output]');
    const preset = root.querySelector<HTMLButtonElement>('[data-preset]');
    const copyBtn = root.querySelector<HTMLButtonElement>('[data-copy-robots]');
    const copyLabel = root.querySelector<HTMLElement>('[data-copy-label]');
    if (!output) return;
    const outputEl = output;

    const toggles = Array.from(root.querySelectorAll<HTMLButtonElement>('.bot-toggle'));
    const signalBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('.signal-btn'));

    const signals: SignalState = { search: 'yes', 'ai-input': 'yes', 'ai-train': 'no' };

    function syncSignalButtons() {
      signalBtns.forEach((btn) => {
        const key = btn.dataset.signal as keyof SignalState | undefined;
        const val = btn.dataset.value as 'yes' | 'no' | undefined;
        if (!key || !val) return;
        btn.dataset.active = signals[key] === val ? 'true' : 'false';
      });
    }

    function currentBots() {
      return toggles.map((t) => ({
        id: t.dataset.bot ?? '',
        state: (t.dataset.state as BotState) ?? 'allowed',
      }));
    }

    function render() {
      outputEl.innerHTML = renderRobotsOutput(currentBots(), signals);
    }

    const TRAINING_BOTS = ['GPTBot', 'ClaudeBot', 'Google-Extended', 'Applebot-Extended', 'Bytespider', 'CCBot', 'meta-externalagent', 'Amazonbot'];

    function syncBotBadges() {
      toggles.forEach((t) => {
        const state = (t.dataset.state as BotState) ?? 'allowed';
        t.setAttribute('aria-pressed', state === 'blocked' ? 'true' : 'false');
        const badge = t.querySelector<HTMLElement>('.bot-badge');
        if (badge) badge.textContent = state === 'blocked' ? 'blocked' : 'allowed';
      });
    }

    function updatePresetLabel() {
      if (!preset) return;
      const allBlocked = toggles
        .filter((t) => TRAINING_BOTS.includes(t.dataset.bot ?? ''))
        .every((t) => t.dataset.state === 'blocked');
      preset.textContent = allBlocked ? 'Allow training bots' : 'Block training bots';
      preset.setAttribute('aria-label', allBlocked ? 'Allow training bots' : 'Block training bots');
      preset.dataset.active = allBlocked ? 'true' : 'false';
    }

    const clickHandlers: Array<{ el: HTMLElement; type: 'click'; fn: (e: Event) => void }> = [];

    toggles.forEach((t) => {
      const fn = () => {
        const state = (t.dataset.state as BotState) ?? 'allowed';
        t.dataset.state = state === 'blocked' ? 'allowed' : 'blocked';
        syncBotBadges();
        updatePresetLabel();
        render();
      };
      t.addEventListener('click', fn);
      clickHandlers.push({ el: t, type: 'click', fn });
    });

    signalBtns.forEach((btn) => {
      const fn = () => {
        const key = btn.dataset.signal as keyof SignalState | undefined;
        const val = btn.dataset.value as 'yes' | 'no' | undefined;
        if (!key || !val) return;
        signals[key] = val;
        syncSignalButtons();
        render();
      };
      btn.addEventListener('click', fn);
      clickHandlers.push({ el: btn, type: 'click', fn });
    });

    if (preset) {
      const fn = () => {
        const allTrainingBlocked = toggles
          .filter((t) => TRAINING_BOTS.includes(t.dataset.bot ?? ''))
          .every((t) => t.dataset.state === 'blocked');

        toggles.forEach((t) => {
          const bot = t.dataset.bot ?? '';
          if (TRAINING_BOTS.includes(bot)) {
            t.dataset.state = allTrainingBlocked ? 'allowed' : 'blocked';
          }
        });
        signals['ai-train'] = allTrainingBlocked ? 'yes' : 'no';
        syncBotBadges();
        syncSignalButtons();
        updatePresetLabel();
        render();
      };
      preset.addEventListener('click', fn);
      clickHandlers.push({ el: preset, type: 'click', fn });
    }

    if (copyBtn && copyLabel) {
      const fn = async () => {
        try {
          await navigator.clipboard.writeText(plainRobotsOutput(currentBots(), signals));
          const original = copyLabel.textContent;
          copyLabel.textContent = 'Copied';
          setTimeout(() => { copyLabel.textContent = original; }, 1600);
        } catch (err) {
          console.error('Clipboard copy failed', err);
        }
      };
      copyBtn.addEventListener('click', fn);
      clickHandlers.push({ el: copyBtn, type: 'click', fn });
    }

    // Initialize
    toggles.forEach((t) => {
      if (!t.dataset.state) t.dataset.state = 'blocked';
    });
    syncBotBadges();
    syncSignalButtons();
    updatePresetLabel();
    render();

    cleanupRobots = () => {
      clickHandlers.forEach(({ el, type, fn }) => el.removeEventListener(type, fn));
      cleanupRobots = null;
    };
  }

  function init() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupRobotsBuilder, { once: true });
    } else {
      setupRobotsBuilder();
    }
  }

  document.addEventListener('astro:page-load', setupRobotsBuilder);
  document.addEventListener('astro:before-swap', () => { if (cleanupRobots) cleanupRobots(); });
  init();
</script>
