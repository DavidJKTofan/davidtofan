---
const pillars = [
  {
    num: '01',
    name: 'Discoverability',
    icon: 'compass',
    desc: 'robots.txt, sitemap, Link headers — so agents can find your surfaces.',
    anchor: '#discoverability',
  },
  {
    num: '02',
    name: 'Content',
    icon: 'doc',
    desc: 'Serve markdown when agents ask for it. Drop 80% of tokens on the wire.',
    anchor: '#content',
  },
  {
    num: '03',
    name: 'Bot Access Control',
    icon: 'shield',
    desc: 'Content Signals, AI Crawl Control, and bot-provider identity via Web Bot Auth — declare and enforce.',
    anchor: '#bot-control',
  },
  {
    num: '04',
    name: 'Capabilities',
    icon: 'plug',
    desc: 'OAuth discovery, API Catalog, MCP Server Cards, Agent Skills.',
    anchor: '#capabilities',
  },
  {
    num: '05',
    name: 'Commerce',
    icon: 'coin',
    desc: 'Pay Per Crawl and x402 — monetize, or block, but stop leaving bytes on the table.',
    anchor: '#commerce',
  },
  {
    num: '+1',
    name: 'Performance',
    icon: 'bolt',
    desc: 'Core Web Vitals, caching, compression, and markdown delivery — so agents do not time out.',
    anchor: '#performance',
    extra: true,
  },
  {
    num: '+2',
    name: 'Security',
    icon: 'lock',
    desc: 'Every /.well-known/ is both an invitation and an attack surface.',
    anchor: '#security',
    extra: true,
  },
];

const iconPaths: Record<string, string> = {
  compass: 'M12 2l3 7 7 3-7 3-3 7-3-7-7-3 7-3z',
  doc: 'M9 12h6m-6 4h6M7 4h10a2 2 0 012 2v14l-4-3H7a2 2 0 01-2-2V6a2 2 0 012-2z',
  shield: 'M12 3l8 4v6c0 5-3.5 7.5-8 9-4.5-1.5-8-4-8-9V7l8-4z',
  plug: 'M9 4v4m6-4v4M6 8h12l-1 11a2 2 0 01-2 2H9a2 2 0 01-2-2L6 8z',
  coin: 'M12 3v18M8 7h7a3 3 0 010 6H9a3 3 0 000 6h7',
  bolt: 'M13 2L3 14h7l-1 8 10-12h-7l1-8z',
  lock: 'M8 11V7a4 4 0 018 0v4M6 11h12v10H6V11z',
};
---

<div class="pillars-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4 my-6">
  {pillars.map((p, i) => (
    <a
      href={p.anchor}
      class:list={[
        'pillar-card group relative block rounded-xl border p-5 transition-all hover:-translate-y-0.5',
        p.extra
          ? 'border-accent-400/50 dark:border-accent-500/40 bg-gradient-to-br from-accent-50 to-surface-50 dark:from-accent-950/50 dark:to-surface-900/60'
          : 'border-surface-200 dark:border-surface-800 bg-surface-50/70 dark:bg-surface-900/40 hover:border-accent-400/60 dark:hover:border-accent-500/40',
      ]}
      style={`--i:${i}`}
    >
      <div class="flex items-center justify-between mb-4">
        <div
          class:list={[
            'inline-flex items-center justify-center w-10 h-10 rounded-lg transition-colors',
            p.extra
              ? 'bg-accent-500/15 text-accent-600 dark:text-accent-400'
              : 'bg-surface-100 dark:bg-surface-800 text-surface-600 dark:text-surface-300 group-hover:bg-accent-500/15 group-hover:text-accent-600 dark:group-hover:text-accent-400',
          ]}
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d={iconPaths[p.icon]} />
          </svg>
        </div>
        <span class="font-mono text-xs text-surface-500 dark:text-surface-400 tabular-nums">{p.num}</span>
      </div>
      <h3 class="font-display font-semibold text-lg text-surface-900 dark:text-surface-50 mb-2">
        {p.name}
      </h3>
      <p class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed">
        {p.desc}
      </p>
      <span class="absolute top-4 right-5 text-surface-300 dark:text-surface-700 opacity-0 group-hover:opacity-100 transition-opacity">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </span>
    </a>
  ))}
</div>

<style>
  .pillar-card {
    opacity: 0;
    transform: translateY(10px);
    animation: pillarIn 0.5s ease-out forwards;
    animation-delay: calc(var(--i) * 0.06s);
  }
  @keyframes pillarIn {
    to { opacity: 1; transform: translateY(0); }
  }
</style>
