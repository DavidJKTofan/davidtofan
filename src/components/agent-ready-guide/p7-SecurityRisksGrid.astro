---
const risks = [
  {
    id: 'injection',
    title: 'Indirect prompt injection',
    ref: 'LLM01',
    summary: 'Content agents read becomes instructions an attacker controls.',
    fix: 'Never inject user content into MCP tool descriptions. Strip remote image markdown from untrusted sources. Enforce human-in-the-loop for destructive tools.',
    productLinks: [
      { label: 'AI Gateway', href: 'https://developers.cloudflare.com/ai-gateway/' },
      { label: 'WAF', href: 'https://developers.cloudflare.com/waf/' },
    ],
  },
  {
    id: 'leakage',
    title: 'Sensitive information disclosure',
    ref: 'LLM02',
    summary: '/.well-known/, sitemaps, MCP cards leak staging paths and runbooks.',
    fix: 'Curate these files explicitly. Gate private trees with Cloudflare Access. Add X-Robots-Tag: noindex on ingestion endpoints you don\'t want indexed.',
    productLinks: [
      { label: 'Cloudflare Access', href: 'https://developers.cloudflare.com/cloudflare-one/access-controls/' },
    ],
  },
  {
    id: 'supply-chain',
    title: 'Supply-chain (MCP)',
    ref: 'LLM03',
    summary: 'Third-party MCP updates can introduce poisoned tool descriptions.',
    fix: 'Pin versions. Diff release notes. Central allowlist. Sandbox on Workers + Durable Objects. Log every tool call via AI Gateway.',
    productLinks: [
      { label: 'AI Gateway', href: 'https://developers.cloudflare.com/ai-gateway/' },
      { label: 'Logpush', href: 'https://developers.cloudflare.com/logs/logpush/' },
      { label: 'Cloudflare Access', href: 'https://developers.cloudflare.com/cloudflare-one/access-controls/' },
    ],
  },
  {
    id: 'authz',
    title: 'Excessive agency (confused deputy)',
    ref: 'LLM06',
    summary: 'MCP servers pass tokens upstream without audience validation.',
    fix: 'OAuth 2.1 + PKCE, RFC 8707 Resource Indicators, RFC 9728 Protected Resource Metadata. Least-privilege scopes per tool. Never passthrough tokens.',
    productLinks: [
      { label: 'Workers OAuth Provider', href: 'https://developers.cloudflare.com/agents/model-context-protocol/authorization/' },
      { label: 'Cloudflare Access', href: 'https://developers.cloudflare.com/cloudflare-one/access-controls/' },
    ],
  },
  {
    id: 'impersonation',
    title: 'Agent impersonation',
    ref: 'LLM07',
    summary: 'UA strings and residential proxies defeat simple allowlists.',
    fix: 'Require cryptographic identity from bot providers: Web Bot Auth (HTTP Message Signatures, RFC 9421), Cloudflare Verified Bots, reverse DNS verification.',
    productLinks: [
      { label: 'Verified Bots', href: 'https://developers.cloudflare.com/bots/concepts/bot/verified-bots/' },
      { label: 'Web Bot Auth', href: 'https://developers.cloudflare.com/bots/reference/bot-verification/web-bot-auth/' },
      { label: 'Cloudflare Access', href: 'https://developers.cloudflare.com/cloudflare-one/access-controls/' },
    ],
  },
  {
    id: 'abuse',
    title: 'Unbounded consumption',
    ref: 'LLM10',
    summary: 'A 38,000:1 crawl-to-refer ratio torches your egress bill.',
    fix: 'AI Crawl Control + Rate Limiting + Bot Management. Use HTTP 402 / Pay Per Crawl for bots you\'d rather charge than block.',
    productLinks: [
      { label: 'AI Crawl Control', href: 'https://developers.cloudflare.com/ai-crawl-control/' },
      { label: 'Rate Limiting', href: 'https://developers.cloudflare.com/waf/rate-limiting-rules/' },
      { label: 'Bot Management', href: 'https://developers.cloudflare.com/bots/' },
      { label: 'AI Gateway', href: 'https://developers.cloudflare.com/ai-gateway/' },
      { label: 'Pay Per Crawl', href: 'https://developers.cloudflare.com/ai-crawl-control/features/pay-per-crawl/what-is-pay-per-crawl/' },
    ],
  },
  {
    id: 'commerce',
    title: 'Agentic commerce fraud',
    ref: 'Agentic',
    summary: 'Replay, impersonation, and unbounded spend by autonomous agents.',
    fix: 'Trusted Agent Protocol. For operators running bots, Web Bot Auth with nonce + created + expires. Spend caps enforced outside the LLM loop.',
    feature: 'Trusted Agent Protocol',
  },
];
---

<div class="my-8">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
    {risks.map((r, i) => (
      <div
        class="risk-card group relative rounded-xl border border-surface-200 dark:border-surface-800 bg-surface-50/70 dark:bg-surface-900/40 p-5 hover:border-accent-400/60 dark:hover:border-accent-500/40 transition-all hover:-translate-y-0.5"
        style={`--i: ${i}`}
        data-risk
      >
        <div class="flex items-start justify-between gap-3 mb-3">
          <div class="inline-flex items-center gap-2">
            <span class="inline-flex items-center justify-center w-7 h-7 rounded-md bg-amber-500/10 text-amber-700 dark:text-amber-400 ring-1 ring-amber-500/20">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M12 9v4m0 4h.01M10.3 3.86l-8.55 14.81A2 2 0 003.5 22h17a2 2 0 001.75-3.33L13.7 3.86a2 2 0 00-3.4 0z" />
              </svg>
            </span>
            <span class="font-mono text-2xs uppercase tracking-wider text-surface-600 dark:text-surface-400">OWASP {r.ref}</span>
          </div>
          <button
            type="button"
            data-risk-toggle
            class="text-2xs font-mono px-2 py-0.5 rounded-md border border-surface-300 dark:border-surface-700 text-surface-500 dark:text-surface-400 hover:text-accent-600 dark:hover:text-accent-400 hover:border-accent-400 transition-colors"
            aria-expanded="false"
          >
            <span data-risk-label>Mitigate</span>
          </button>
        </div>
        <h3 class="font-display font-semibold text-base text-surface-900 dark:text-surface-50 mb-1.5">
          {r.title}
        </h3>
        <p class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed" data-risk-summary>
          {r.summary}
        </p>
        <div class="risk-fix mt-3 text-sm text-surface-700 dark:text-surface-300 leading-relaxed border-l-2 border-accent-500/50 pl-3" data-risk-fix>
          {r.fix}
          <div class="mt-2 flex flex-wrap items-center gap-2 text-2xs font-mono uppercase tracking-wider text-accent-600 dark:text-accent-400">
            <span aria-hidden="true">→</span>
            {r.productLinks ? r.productLinks.map((product) => (
              <a
                href={product.href}
                target="_blank"
                rel="noopener noreferrer"
                class="risk-product-link underline decoration-accent-400/40 underline-offset-2 hover:decoration-accent-500"
              >
                {product.label}
              </a>
            )) : (
              <span>{r.feature}</span>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>

  <blockquote class="mt-8 relative rounded-xl border-l-2 border-accent-500 bg-accent-50/40 dark:bg-accent-950/30 p-5 sm:p-6">
    <p class="font-display text-lg sm:text-xl font-medium text-surface-800 dark:text-surface-100 leading-snug text-balance">
      Every <code class="px-1.5 py-0.5 rounded bg-surface-100 dark:bg-surface-800 text-base font-mono">/.well-known/</code> endpoint you publish is both an invitation and an attack surface. Treat them accordingly.
    </p>
  </blockquote>
</div>

<style>
  .risk-card {
    opacity: 0;
    transform: translateY(8px);
    animation: riskIn 0.5s ease-out forwards;
    animation-delay: calc(var(--i) * 0.05s);
  }
  @keyframes riskIn { to { opacity: 1; transform: translateY(0); } }
  .risk-fix {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.35s ease, opacity 0.25s ease, margin-top 0.35s ease;
    margin-top: 0;
  }
  .risk-card[data-expanded="true"] .risk-fix {
    max-height: 420px;
    opacity: 1;
    margin-top: 0.75rem;
  }
</style>

<script>
  let cleanupRisks: (() => void) | null = null;

  function setupRisks() {
    if (cleanupRisks) cleanupRisks();
    const cards = Array.from(document.querySelectorAll<HTMLDivElement>('[data-risk]'));
    if (!cards.length) return;

    const handlers: Array<{ el: HTMLElement; fn: () => void }> = [];

    cards.forEach((card) => {
      const btn = card.querySelector<HTMLButtonElement>('[data-risk-toggle]');
      const label = card.querySelector<HTMLElement>('[data-risk-label]');
      if (!btn || !label) return;
      const fn = () => {
        const expanded = card.dataset.expanded === 'true';
        card.dataset.expanded = expanded ? 'false' : 'true';
        btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
        label.textContent = expanded ? 'Mitigate' : 'Hide';
      };
      btn.addEventListener('click', fn);
      handlers.push({ el: btn, fn });
    });

    cleanupRisks = () => {
      handlers.forEach(({ el, fn }) => el.removeEventListener('click', fn));
      cleanupRisks = null;
    };
  }

  function init() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupRisks, { once: true });
    } else {
      setupRisks();
    }
  }

  document.addEventListener('astro:page-load', setupRisks);
  document.addEventListener('astro:before-swap', () => { if (cleanupRisks) cleanupRisks(); });
  init();
</script>
