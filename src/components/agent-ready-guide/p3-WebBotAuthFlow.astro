---
// Web Bot Auth handshake — Ed25519 HTTP Message Signatures (RFC 9421)
---

<div class="my-8 rounded-2xl border border-accent-500/40 dark:border-accent-500/30 bg-surface-50/50 dark:bg-surface-950/60 overflow-hidden shadow-lg shadow-accent-500/5">
  <div class="flex items-center justify-between gap-4 px-5 py-3 border-b border-surface-200 dark:border-surface-800 bg-gradient-to-r from-accent-500/10 to-transparent">
    <div class="flex items-center gap-2 min-w-0">
      <span class="wba-dot flex-shrink-0"></span>
      <span class="text-xs font-mono uppercase tracking-wider font-bold text-accent-700 dark:text-accent-300 truncate">
        Web Bot Auth · Ed25519 handshake
      </span>
    </div>
    <a
      href="https://developers.cloudflare.com/bots/reference/bot-verification/web-bot-auth/"
      target="_blank"
      rel="noopener noreferrer"
      class="text-2xs font-mono text-accent-700 dark:text-accent-300 hover:underline flex-shrink-0"
    >docs →</a>
  </div>

  <div class="p-5 sm:p-6">
    <!-- Swimlane header -->
    <div class="wba-lanes grid grid-cols-3 gap-2 mb-4 text-2xs font-mono uppercase tracking-wider">
      <div class="text-center py-2 rounded-md bg-surface-100/70 dark:bg-surface-900/60 border border-surface-200 dark:border-surface-800 text-surface-600 dark:text-surface-400">Bot operator</div>
      <div class="text-center py-2 rounded-md bg-surface-100/70 dark:bg-surface-900/60 border border-surface-200 dark:border-surface-800 text-surface-600 dark:text-surface-400">Public key directory</div>
      <div class="text-center py-2 rounded-md bg-surface-100/70 dark:bg-surface-900/60 border border-surface-200 dark:border-surface-800 text-surface-600 dark:text-surface-400">Cloudflare edge</div>
    </div>

    <ol class="space-y-3">
      <!-- Step 1: operator publishes JWKS -->
      <li class="wba-step" style="--i: 0">
        <div class="wba-row grid grid-cols-3 gap-2 items-stretch">
          <div class="wba-card wba-card-origin" data-lane="Bot operator">
            <div class="flex items-center gap-2 mb-1">
              <span class="w-5 h-5 rounded-full bg-surface-200 dark:bg-surface-800 text-surface-700 dark:text-surface-300 flex items-center justify-center font-mono text-2xs font-semibold">1</span>
              <span class="text-2xs font-mono uppercase tracking-wider text-surface-600 dark:text-surface-400">Publish JWKS</span>
            </div>
            <pre class="text-2xs font-mono text-surface-700 dark:text-surface-300 m-0 overflow-x-auto"><code>GET /.well-known/
  http-message-
  signatures-directory</code></pre>
          </div>
          <div class="wba-arrow wba-arrow-right"><span class="wba-packet wba-packet-right"></span></div>
          <div class="wba-card wba-card-dim wba-card-note" data-lane="Public key directory">
            <div class="text-2xs font-mono text-surface-600 dark:text-surface-400">
              JWKS hosted<br/>
              <code class="text-accent-700 dark:text-accent-300">kid</code> + Ed25519 public key
            </div>
          </div>
        </div>
      </li>

      <!-- Step 2: bot sends signed request -->
      <li class="wba-step" style="--i: 1">
        <div class="wba-row grid grid-cols-3 gap-2 items-stretch">
          <div class="wba-card wba-card-origin" data-lane="Bot operator">
            <div class="flex items-center gap-2 mb-1">
              <span class="w-5 h-5 rounded-full bg-accent-500/20 text-accent-700 dark:text-accent-400 ring-1 ring-accent-500/40 flex items-center justify-center font-mono text-2xs font-semibold">2</span>
              <span class="text-2xs font-mono uppercase tracking-wider text-surface-600 dark:text-surface-400">Signed request</span>
            </div>
            <pre class="text-2xs font-mono text-surface-700 dark:text-surface-300 m-0 overflow-x-auto"><code>GET /api/data
<span class="text-accent-700 dark:text-accent-300">Signature-Agent:</span>
  "https://claude.ai"
<span class="text-accent-700 dark:text-accent-300">Signature-Input:</span>
  sig1=("@authority"
    "signature-agent");
  created=1752953825;
  expires=1752957425;
  keyid="poqkLGiymh_W0uP6...";
  alg="ed25519";
  tag="web-bot-auth"
<span class="text-accent-700 dark:text-accent-300">Signature:</span>
  sig1=:3NxHWBjJUw...:</code></pre>
          </div>
          <div class="wba-arrow wba-arrow-skip"><span class="wba-packet wba-packet-skip"></span></div>
          <div class="wba-card wba-card-edge" data-lane="Cloudflare edge">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-2xs font-mono uppercase tracking-wider text-accent-700 dark:text-accent-300">Arrives at edge</span>
            </div>
            <div class="text-2xs font-mono text-surface-600 dark:text-surface-400">
              Headers per<br/>
              <a href="https://www.rfc-editor.org/rfc/rfc9421" target="_blank" rel="noopener noreferrer" class="text-accent-700 dark:text-accent-300 hover:underline">RFC 9421</a>
            </div>
          </div>
        </div>
      </li>

      <!-- Step 3: Cloudflare fetches JWKS + verifies -->
      <li class="wba-step" style="--i: 2">
        <div class="wba-row grid grid-cols-3 gap-2 items-stretch">
          <div class="wba-card wba-card-dim wba-card-note" data-lane="Bot operator">
            <div class="text-2xs font-mono text-surface-600 dark:text-surface-400">
              (Listed in<br/>
              <a href="https://github.com/cloudflareresearch/web-bot-auth" target="_blank" rel="noopener noreferrer" class="text-accent-700 dark:text-accent-300 hover:underline">web-bot-auth registry</a>)
            </div>
          </div>
          <div class="wba-arrow wba-arrow-left"><span class="wba-packet wba-packet-left"></span></div>
          <div class="wba-card wba-card-edge" data-lane="Cloudflare edge">
            <div class="flex items-center gap-2 mb-1">
              <span class="w-5 h-5 rounded-full bg-emerald-500/20 text-emerald-700 dark:text-emerald-400 ring-1 ring-emerald-500/40 flex items-center justify-center font-mono text-2xs font-semibold">3</span>
              <span class="text-2xs font-mono uppercase tracking-wider text-emerald-700 dark:text-emerald-400">Verify</span>
            </div>
            <pre class="text-2xs font-mono text-surface-700 dark:text-surface-300 m-0 overflow-x-auto"><code>fetch JWKS → key
verify Ed25519 sig
<span class="text-emerald-600 dark:text-emerald-400">cf.bot_management.
  verified_bot = true</span></code></pre>
          </div>
        </div>
      </li>

      <!-- Step 4: policy decision -->
      <li class="wba-step" style="--i: 3">
        <div class="wba-row grid grid-cols-3 gap-2 items-stretch">
          <div class="wba-card wba-card-dim wba-card-empty"></div>
          <div class="wba-arrow wba-arrow-none"></div>
          <div class="wba-card wba-card-edge" data-lane="Cloudflare edge">
            <div class="flex items-center gap-2 mb-1">
              <span class="w-5 h-5 rounded-full bg-emerald-500/20 text-emerald-700 dark:text-emerald-400 ring-1 ring-emerald-500/40 flex items-center justify-center font-mono text-2xs font-semibold">4</span>
              <span class="text-2xs font-mono uppercase tracking-wider text-emerald-700 dark:text-emerald-400">Enforce</span>
            </div>
            <div class="text-2xs font-mono text-surface-700 dark:text-surface-300 space-y-0.5">
              <div><span class="text-emerald-600 dark:text-emerald-400">allow →</span> origin</div>
              <div><span class="text-amber-600 dark:text-amber-400">charge →</span> HTTP 402</div>
              <div><span class="text-red-600 dark:text-red-400">block →</span> WAF action</div>
            </div>
          </div>
        </div>
      </li>
    </ol>
  </div>

  <div class="px-5 py-3 border-t border-surface-200 dark:border-surface-800 bg-surface-50 dark:bg-surface-900/40">
    <p class="text-xs text-surface-600 dark:text-surface-400 leading-relaxed">
      Operators publish an Ed25519 public key; Cloudflare verifies the signature per
      <a href="https://www.rfc-editor.org/rfc/rfc9421" target="_blank" rel="noopener noreferrer" class="underline decoration-dotted hover:text-accent-600 dark:hover:text-accent-400">RFC 9421</a> on every request.
      Identity becomes cryptographic — user-agent spoofing stops working. This is primarily a bot-operator protocol: organizations that run bots publish keys and sign requests, while site owners mostly use Cloudflare's verification result to allow, charge, or block. Cloudflare uses Web Bot Auth for both verified bots and signed agents, but a bot can only be registered as one classification.
    </p>
  </div>
</div>

<style>
  .wba-dot {
    position: relative;
    display: inline-block;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background-color: rgb(16 185 129);
  }
  .wba-dot::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 9999px;
    background-color: rgb(16 185 129 / 0.4);
    animation: wbaDotPulse 1.8s ease-out infinite;
  }
  @keyframes wbaDotPulse {
    0% { transform: scale(0.6); opacity: 0.9; }
    100% { transform: scale(2); opacity: 0; }
  }

  .wba-card {
    padding: 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid rgb(214 211 209);
    background: rgb(250 250 249 / 0.6);
    min-height: 4rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  :global(.dark) .wba-card {
    border-color: rgb(41 37 36);
    background: rgb(28 25 23 / 0.6);
  }
  .wba-card-edge {
    border-color: rgb(59 130 246 / 0.4);
    background: rgb(59 130 246 / 0.05);
  }
  :global(.dark) .wba-card-edge {
    border-color: rgb(59 130 246 / 0.3);
    background: rgb(59 130 246 / 0.08);
  }
  .wba-card-dim {
    opacity: 0.45;
    background: transparent;
    border-style: dashed;
  }

  .wba-arrow {
    position: relative;
    min-height: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .wba-arrow-right::after,
  .wba-arrow-left::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 10%;
    right: 10%;
    height: 2px;
    background: linear-gradient(90deg, rgb(59 130 246 / 0.3), rgb(59 130 246 / 0.6));
    transform: translateY(-50%);
  }
  .wba-arrow-right::before {
    content: '▶';
    position: absolute;
    top: 50%;
    right: 8%;
    transform: translateY(-50%);
    color: rgb(59 130 246);
    font-size: 0.625rem;
  }
  .wba-arrow-left::after {
    background: linear-gradient(90deg, rgb(59 130 246 / 0.6), rgb(59 130 246 / 0.3));
  }
  .wba-arrow-left::before {
    content: '◀';
    position: absolute;
    top: 50%;
    left: 8%;
    transform: translateY(-50%);
    color: rgb(59 130 246);
    font-size: 0.625rem;
  }
  .wba-arrow-skip::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 2px;
    background: repeating-linear-gradient(90deg,
      rgb(59 130 246 / 0.5) 0 6px,
      transparent 6px 12px);
    transform: translateY(-50%);
  }
  .wba-arrow-skip::before {
    content: '▶';
    position: absolute;
    top: 50%;
    right: 4%;
    transform: translateY(-50%);
    color: rgb(59 130 246);
    font-size: 0.625rem;
  }

  .wba-step {
    opacity: 0;
    transform: translateY(6px);
    animation: wbaStepIn 0.45s ease-out forwards;
    animation-delay: calc(var(--i) * 0.12s + 0.1s);
  }
  @keyframes wbaStepIn {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Animated packets travelling along arrows */
  .wba-packet {
    position: absolute;
    top: 50%;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 9999px;
    background: rgb(59 130 246);
    box-shadow: 0 0 0 3px rgb(59 130 246 / 0.2), 0 0 12px rgb(59 130 246 / 0.55);
    transform: translateY(-50%);
    opacity: 0;
  }
  .wba-packet-right {
    left: 10%;
    animation: wbaPacketRight 2.6s ease-in-out infinite;
    animation-delay: 0.4s;
  }
  .wba-packet-skip {
    left: 0;
    animation: wbaPacketSkip 2.6s ease-in-out infinite;
    animation-delay: 0.9s;
  }
  .wba-packet-left {
    right: 10%;
    animation: wbaPacketLeft 2.6s ease-in-out infinite;
    animation-delay: 1.4s;
  }
  @keyframes wbaPacketRight {
    0% { left: 10%; opacity: 0; }
    15% { opacity: 1; }
    85% { opacity: 1; }
    100% { left: 90%; opacity: 0; }
  }
  @keyframes wbaPacketSkip {
    0% { left: 0; opacity: 0; }
    15% { opacity: 1; }
    85% { opacity: 1; }
    100% { left: 100%; opacity: 0; }
  }
  @keyframes wbaPacketLeft {
    0% { right: 10%; opacity: 0; }
    15% { opacity: 1; }
    85% { opacity: 1; }
    100% { right: 90%; opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .wba-dot::before { animation: none; }
    .wba-step { animation: none; opacity: 1; transform: none; }
    .wba-packet { animation: none; opacity: 0; }
  }

  @media (max-width: 640px) {
    .wba-lanes { display: none; }
    .wba-row { grid-template-columns: minmax(0, 1fr); }
    .wba-arrow, .wba-card-empty { display: none; }
    .wba-card {
      min-height: auto;
      padding: 0.625rem;
    }
    .wba-card pre { font-size: 0.625rem; }
    .wba-card-note { opacity: 1; }
    .wba-card[data-lane]::before {
      content: attr(data-lane);
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.625rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: rgb(120 113 108);
      margin-bottom: 0.375rem;
    }
    :global(.dark) .wba-card[data-lane]::before {
      color: rgb(168 162 158);
    }
  }
</style>
