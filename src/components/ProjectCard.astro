---
interface Props {
  title: string;
  description: string;
  slug: string;
  website?: string;
  github?: string;
  tags?: string[];
  status?: 'active' | 'completed' | 'archived';
  featured?: boolean;
}

const { title, description, slug, website, github, tags = [], status = 'active', featured = false } = Astro.props;

const statusColors = {
  active: 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400',
  completed: 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400',
  archived: 'bg-surface-100 dark:bg-surface-800 text-surface-600 dark:text-surface-400',
};
---

<article class="group">
  <div class="card p-6 h-full">
    <div class="flex flex-col h-full">
      <!-- Header -->
      <div class="flex items-start justify-between gap-3 mb-3">
        <div class="flex items-center gap-2">
          <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${statusColors[status]}`}>
            {status.charAt(0).toUpperCase() + status.slice(1)}
          </span>
          {featured && (
            <span class="tag tag-accent">
              Featured
            </span>
          )}
        </div>
        
        <!-- External links -->
        <div class="flex items-center gap-1">
          {website && (
            <a
              href={website}
              target="_blank"
              rel="noopener noreferrer"
              class="p-1.5 rounded-md text-surface-400 hover:text-accent-500 hover:bg-surface-100 dark:hover:bg-surface-800 transition-colors duration-200"
              title="Visit website"
              aria-label={`Visit ${title} website`}
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          )}
          {github && (
            <a
              href={github}
              target="_blank"
              rel="noopener noreferrer"
              class="p-1.5 rounded-md text-surface-400 hover:text-accent-500 hover:bg-surface-100 dark:hover:bg-surface-800 transition-colors duration-200"
              title="View source"
              aria-label={`View ${title} source`}
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
              </svg>
            </a>
          )}
        </div>
      </div>

      <a href={`/projects/${slug}`} class="flex flex-1 flex-col">
        <!-- Title -->
        <h3 class="font-display font-semibold text-lg text-surface-900 dark:text-surface-100 mb-2 group-hover:text-accent-600 dark:group-hover:text-accent-400 transition-colors duration-200 line-clamp-2">
          {title}
        </h3>

        <!-- Description -->
        <p class="text-surface-600 dark:text-surface-400 text-[15px] sm:text-sm leading-relaxed mb-4 line-clamp-3 flex-1">
          {description}
        </p>

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-auto">
            {tags.slice(0, 4).map((tag) => (
              <span class="tag">
                {tag}
              </span>
            ))}
          </div>
        )}
      </a>
    </div>
  </div>
</article>
