---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// Filter to only h2 and h3
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav 
    class="toc pl-4 border-l border-surface-200 dark:border-surface-800" 
    aria-label="Table of Contents"
  >
    <div class="flex items-center gap-2 mb-3">
      <span class="text-xs font-semibold text-surface-500 dark:text-surface-400 uppercase tracking-wider">
        On this page
      </span>
    </div>
    <ul class="toc-list">
      {filteredHeadings.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class:list={[
              'toc-link',
              heading.depth === 2 ? 'toc-link-depth-2' : 'toc-link-depth-3',
            ]}
            data-toc-link
            data-heading={heading.slug}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .toc-list {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .toc-link {
    position: relative;
    display: grid;
    grid-template-columns: 1.25rem minmax(0, 1fr);
    align-items: center;
    column-gap: 0.45rem;
    min-height: 1.8rem;
    border-radius: 0.375rem;
    padding: 0.125rem 0.35rem 0.125rem 0;
    color: rgb(120 113 108);
    font-size: 0.875rem;
    line-height: 1.35;
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .toc-link::before {
    content: '';
    width: 2px;
    border-radius: 999px;
    background-color: rgb(231 229 228);
    justify-self: center;
    transition:
      background-color 0.2s ease,
      height 0.2s ease,
      width 0.2s ease;
  }

  .toc-link-depth-2 {
    color: rgb(87 83 78);
    font-weight: 500;
  }

  .toc-link-depth-2::before {
    height: 1.65rem;
    background-color: rgb(214 211 209);
  }

  .toc-link-depth-3 {
    grid-template-columns: 1.5rem minmax(0, 1fr);
    color: rgb(135 128 120);
    font-size: 0.8125rem;
    font-weight: 400;
  }

  .toc-link-depth-3::before {
    height: 0.9rem;
  }

  .toc-link:hover {
    color: rgb(37 99 235);
  }

  .toc-link:hover::before {
    background-color: rgb(168 162 158);
  }

  .toc-link.active {
    background-color: rgb(37 99 235 / 0.08);
    color: rgb(29 78 216);
    font-weight: 600;
  }

  .toc-link.active::before {
    width: 4px;
    background-color: var(--color-accent-500);
  }

  .toc-link-depth-2.active::before {
    height: 1.75rem;
  }

  .toc-link-depth-3.active::before {
    height: 1rem;
  }

  :global(.dark) .toc-link {
    color: rgb(120 113 108);
  }

  :global(.dark) .toc-link-depth-2 {
    color: rgb(168 162 158);
    font-weight: 500;
  }

  :global(.dark) .toc-link-depth-3 {
    color: rgb(146 137 128);
  }

  :global(.dark) .toc-link::before {
    background-color: rgb(68 64 60);
  }

  :global(.dark) .toc-link-depth-2::before {
    background-color: rgb(87 83 78);
  }

  :global(.dark) .toc-link:hover {
    color: rgb(96 165 250);
  }

  :global(.dark) .toc-link:hover::before {
    background-color: rgb(120 113 108);
  }
  
  :global(.dark) .toc-link.active {
    background-color: rgb(96 165 250 / 0.12);
    color: rgb(147 197 253);
    font-weight: 600;
  }

  :global(.dark) .toc-link.active::before {
    background-color: var(--color-accent-400);
  }
</style>

<script>
  let cleanupTableOfContents = () => {};

  function initTableOfContents() {
    cleanupTableOfContents();

    const tocLinks = document.querySelectorAll('[data-toc-link]');
    const headings = document.querySelectorAll('article h2[id], article h3[id], section[id]');
    
    if (!tocLinks.length || !headings.length) {
      cleanupTableOfContents = () => {};
      return;
    }

    const removeLinkListeners: Array<() => void> = [];

    // Scroll to heading on click
    tocLinks.forEach((link) => {
      const onClick = (e: Event) => {
        e.preventDefault();
        const href = link.getAttribute('href');
        if (!href) return;
        
        const targetId = href.substring(1);
        const target = document.getElementById(targetId);
        
        if (target) {
          const headerOffset = 100;
          const elementPosition = target.getBoundingClientRect().top;
          const offsetPosition = elementPosition + window.scrollY - headerOffset;
          
          window.scrollTo({
            top: offsetPosition,
            behavior: 'smooth',
          });
          
          // Update URL hash without jumping
          history.pushState(null, '', href);
        }
      };

      link.addEventListener('click', onClick);
      removeLinkListeners.push(() => link.removeEventListener('click', onClick));
    });

    // Highlight current section on scroll
    let currentActive: Element | null = null;

    const observerOptions = {
      rootMargin: '-100px 0px -66%',
      threshold: 0,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          if (!id) return;
          
          // Remove active from previous
          if (currentActive) {
            currentActive.classList.remove('active');
            currentActive.removeAttribute('aria-current');
          }
          
          // Add active to matching link
          const matchingLink = document.querySelector(`[data-toc-link][data-heading="${id}"]`);
          if (matchingLink) {
            matchingLink.classList.add('active');
            matchingLink.setAttribute('aria-current', 'true');
            currentActive = matchingLink;
          }
        }
      });
    }, observerOptions);

    headings.forEach((heading) => {
      observer.observe(heading);
    });

    cleanupTableOfContents = () => {
      observer.disconnect();
      removeLinkListeners.forEach((removeListener) => removeListener());
    };
  }

  function setupTableOfContents() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTableOfContents, { once: true });
    } else {
      initTableOfContents();
    }
  }

  // Initialize on page load
  document.addEventListener('astro:page-load', initTableOfContents);
  document.addEventListener('astro:before-swap', () => cleanupTableOfContents());
  setupTableOfContents();
</script>
