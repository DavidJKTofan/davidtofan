---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';
import { calculateReadingTime } from '../../lib/readingTime';
import { siteConfig } from '../../config/site';
import { getContentImagePath, getEffectiveModifiedTime } from '../../lib/contentMetadata.js';

export async function getStaticPaths() {
  const CUSTOM_ARTICLE_PAGES = new Set<string>([
    'ai-agent-ready-website-cloudflare-guide',
  ]);
  const articles = await getCollection(
    'articles',
    ({ data, id }) => !data.draft && !CUSTOM_ARTICLE_PAGES.has(id)
  );
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content, headings } = await render(article);

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(article.data.date);

// Reading time — frontmatter override wins, else compute from body via shared
// helper so the article page matches the listing cards exactly.
const readingTime = article.data.readingTime
  ?? parseInt(calculateReadingTime(article.body), 10);

// Use article's image if set, otherwise use featured.png from article folder
const articleImage = getContentImagePath('articles', article.id, article.data.image);
const articleUpdatedAt = getEffectiveModifiedTime(article.data);
---

<BaseLayout
  title={article.data.title}
  description={article.data.description}
  type="article"
  publishedTime={article.data.date}
  modifiedTime={articleUpdatedAt}
  tags={article.data.tags}
  image={articleImage}
>
  <ReadingProgress />
  <ScrollToTop />

  <!--
    ┌─ Responsive layout strategy ─────────────────────────────────────────────┐
    │                                                                           │
    │  < lg  (< 1024px)  Single column. TOC hidden.                            │
    │  lg    (≥ 1024px)  CSS Grid: [1fr  |  15rem] gap-10                     │
    │  xl    (≥ 1280px)  CSS Grid: [1fr  |  17rem] gap-12, wider container    │
    │  2xl+  (≥ 1536px)  Container caps at max-w-6xl (72rem / 1152px),        │
    │                    centred — content never stretches to unreadable width  │
    │                                                                           │
    │  TOC positioning technique:                                               │
    │  ─ The grid's second column holds an invisible "anchor" <div>.           │
    │  ─ The actual <aside> TOC is position:fixed and sits outside the grid.   │
    │  ─ A small JS snippet reads anchor.getBoundingClientRect() on load and   │
    │    on every resize, then mirrors its left + width to the fixed sidebar.  │
    │  ─ This gives a permanently-visible, viewport-fixed TOC that is always   │
    │    correctly placed regardless of screen width or scroll position,        │
    │    without any fragile hardcoded calc() math.                            │
    └───────────────────────────────────────────────────────────────────────────┘
  -->

  <!-- ── Page wrapper ──────────────────────────────────────────────────────── -->
  <div class="max-w-5xl xl:max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="lg:grid lg:grid-cols-[1fr_15rem] xl:grid-cols-[1fr_17rem] lg:gap-10 xl:gap-12 lg:items-start">

      <!-- ── Main article column ─────────────────────────────────────────── -->
      <div class="min-w-0">

        <!-- Back link -->
        <a
          href="/articles"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-surface-500 dark:text-surface-400 hover:text-accent-600 dark:hover:text-accent-400 transition-colors mb-8 group"
        >
          <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7" />
          </svg>
          Back to articles
        </a>

        <!-- Article header -->
        <header class="mb-10">
          <!-- Tags -->
          {article.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-4">
              {article.data.tags.slice(0, 4).map((tag: string) => (
                <span class="tag tag-accent text-sm sm:text-xs">
                  {tag}
                </span>
              ))}
            </div>
          )}

          <!-- Title -->
          <h1 class="font-display font-bold text-3xl sm:text-4xl md:text-5xl text-surface-900 dark:text-surface-100 leading-tight mb-6 text-balance">
            {article.data.title}
          </h1>

          <!-- Meta info -->
          <div class="flex flex-wrap items-center gap-4 text-surface-500 dark:text-surface-400">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-gradient-to-br from-accent-400 to-accent-600 flex items-center justify-center">
                <span class="text-white text-xs font-bold">DT</span>
              </div>
              <span class="font-medium text-surface-700 dark:text-surface-300">David Tofan</span>
            </div>

            <span class="w-1 h-1 rounded-full bg-surface-300 dark:bg-surface-600"></span>

            <time datetime={article.data.date.toISOString()} class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="4" width="18" height="18" rx="2" />
                <path d="M16 2v4M8 2v4M3 10h18" />
              </svg>
              {formattedDate}
            </time>

            <span class="w-1 h-1 rounded-full bg-surface-300 dark:bg-surface-600"></span>

            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10" />
                <path d="M12 6v6l4 2" />
              </svg>
              {readingTime} min read
            </span>
          </div>
        </header>

        <!-- Article content -->
        <!-- prose-base = 16px, prose-lg = 18px on sm+ for better readability -->
        <!-- max-w-none lets the grid column control width (no double-constraining) -->
        <article class="prose prose-base sm:prose-lg dark:prose-invert max-w-none">
          <Content />
        </article>

        <!-- Article footer -->
        <footer id="article-footer" class="mt-12 pt-8 border-t border-surface-200 dark:border-surface-800">
          <!-- Tags -->
          {article.data.tags.length > 0 && (
            <div class="mb-8">
              <h3 class="text-sm font-semibold text-surface-700 dark:text-surface-300 uppercase tracking-wide mb-3">
                Topics
              </h3>
              <div class="flex flex-wrap gap-2">
                {article.data.tags.map((tag: string) => (
                  <a
                    href={`/articles?tag=${encodeURIComponent(tag)}`}
                    class="tag hover:bg-accent-100 hover:text-accent-700 dark:hover:bg-accent-900/30 dark:hover:text-accent-400"
                  >
                    {tag}
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Share -->
          <div>
            <h3 class="text-sm font-semibold text-surface-700 dark:text-surface-300 uppercase tracking-wide mb-3">
              Share this article
            </h3>
            <div class="flex items-center gap-2">
              <a
                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(article.data.title)}&url=${encodeURIComponent(Astro.url.href)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-ghost p-2"
                aria-label="Share on Twitter"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                </svg>
              </a>
              <a
                href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(Astro.url.href)}&title=${encodeURIComponent(article.data.title)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-ghost p-2"
                aria-label="Share on LinkedIn"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
              </a>
              <button
                class="btn-ghost p-2"
                aria-label="Copy link"
                id="copy-link-btn"
                data-url={Astro.url.href}
              >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                </svg>
              </button>
            </div>
          </div>
        </footer>
      </div>

      <!-- ── TOC anchor — invisible grid placeholder, lg+ only ──────────── -->
      <!--
        This div is NOT the visible TOC. It is a zero-content placeholder that
        occupies the grid's second column so the article column is correctly
        constrained. Its getBoundingClientRect() is read by JS to position the
        real fixed <aside> below. Keeping them separate means the grid handles
        all the centering math, while the TOC is truly fixed to the viewport.
      -->
      <div id="toc-anchor" class="hidden lg:block" aria-hidden="true"></div>

    </div>
  </div>

  <!-- ── Fixed TOC sidebar — lives outside the grid, positioned by JS ───── -->
  <!--
    position:fixed + JS-mirrored left/width from #toc-anchor means:
    • The TOC is always visible on screen regardless of scroll position.
    • It aligns perfectly with the grid column on every screen width.
    • top: 6rem  = below the fixed header (h-16 mobile / h-18 md).
    • max-height  = remaining viewport height so it scrolls internally when
      the article has many sections.
  -->
  <aside
    id="toc-sidebar"
    class="hidden lg:flex flex-col fixed z-30"
    style="top: 6rem; max-height: calc(100vh - 7rem);"
    aria-label="Table of contents"
  >
    <div class="overflow-y-auto scrollbar-hide flex-1">
      <TableOfContents headings={headings} />
    </div>
  </aside>

  <!-- JSON-LD BreadcrumbList — helps agents understand the hierarchy without
       having to infer from the URL. Schema.org / Google-recognised. -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home",     "item": `${siteConfig.url}/` },
      { "@type": "ListItem", "position": 2, "name": "Articles", "item": `${siteConfig.url}/articles/` },
      { "@type": "ListItem", "position": 3, "name": article.data.title, "item": `${siteConfig.url}/articles/${article.id}/` },
    ],
  })} />
</BaseLayout>

<script>
  let cleanupArticlePage = () => {};

  // ── Copy-link button ──────────────────────────────────────────────────────
  function setupCopyLink() {
    const copyBtn = document.getElementById('copy-link-btn');
    if (!(copyBtn instanceof HTMLButtonElement)) return () => {};

    const onClick = async () => {
      const url = (copyBtn as HTMLElement).dataset.url;
      if (!url) return;

      try {
        await navigator.clipboard.writeText(url);

        const originalHTML = copyBtn.innerHTML;
        copyBtn.innerHTML = `
          <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M5 13l4 4L19 7" />
          </svg>
        `;
        setTimeout(() => { copyBtn.innerHTML = originalHTML; }, 2000);
      } catch (err) {
        console.error('Failed to copy:', err);
      }
    };

    copyBtn.addEventListener('click', onClick);

    return () => {
      copyBtn.removeEventListener('click', onClick);
    };
  }

  // ── Fixed TOC positioning ─────────────────────────────────────────────────
  //
  // Two separate concerns, handled together on every frame:
  //
  //  1. HORIZONTAL  — read #toc-anchor's getBoundingClientRect() and mirror its
  //                   left + width onto the fixed sidebar. The CSS Grid handles
  //                   all centering math; we just copy the result.
  //
  //  2. VERTICAL    — clamp the sidebar's max-height so it never overlaps the
  //                   footer. We compute:
  //
  //       available = footerTop(viewport-relative) - TOC_TOP - BOTTOM_GAP
  //
  //     where TOC_TOP = 96px (top: 6rem, the value set in the HTML style attr)
  //     and BOTTOM_GAP = 16px of breathing room above the footer.
  //     When the footer scrolls into view, available shrinks smoothly and the
  //     TOC content becomes internally scrollable before it would ever overlap.
  //
  const TOC_TOP    = 96; // matches `top: 6rem` on #toc-sidebar
  const BOTTOM_GAP = 16; // px of breathing room above the footer

  function updateTOCSidebar() {
    const anchor  = document.getElementById('toc-anchor');
    const sidebar = document.getElementById('toc-sidebar');
    // Use the article's own footer id (not `querySelector('footer')`) so that
    // markdown-rendered <footer> elements inside the content (e.g. blockquote
    // citations) don't hijack the clamp calculation and collapse the sidebar.
    const footer  = document.getElementById('article-footer');
    if (!anchor || !sidebar) return;

    // On mobile / tablet the sidebar is hidden via CSS — clear inline styles.
    if (window.innerWidth < 1024) {
      sidebar.style.left      = '';
      sidebar.style.width     = '';
      sidebar.style.maxHeight = '';
      return;
    }

    // 1. Horizontal placement — copy the anchor column's viewport position.
    const rect = anchor.getBoundingClientRect();
    sidebar.style.left  = `${rect.left}px`;
    sidebar.style.width = `${rect.width}px`;

    // 2. Vertical clamping — shrink max-height once the footer enters view.
    //    footer.getBoundingClientRect().top is the footer's distance from the
    //    top of the viewport (negative when scrolled past it).
    const viewportHeight = window.innerHeight;
    let maxH: number;
    if (footer) {
      const footerTop = footer.getBoundingClientRect().top;
      // How much vertical space is available between the TOC top and the footer.
      const available = footerTop - TOC_TOP - BOTTOM_GAP;
      // Never exceed the viewport minus header; never go below 0.
      const viewportBound = viewportHeight - TOC_TOP - BOTTOM_GAP;
      maxH = Math.max(0, Math.min(available, viewportBound));
    } else {
      maxH = viewportHeight - TOC_TOP - BOTTOM_GAP;
    }
    sidebar.style.maxHeight = `${maxH}px`;
  }

  // Debounce resize; scroll runs every frame so no debounce needed there.
  let resizeTimer: ReturnType<typeof setTimeout>;
  function onResize() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(updateTOCSidebar, 60);
  }

  function setup() {
    cleanupArticlePage();

    const cleanupCopyLink = setupCopyLink();
    updateTOCSidebar();
    // Scroll: recalculate max-height on every scroll tick (cheap DOM read).
    window.addEventListener('scroll', updateTOCSidebar, { passive: true });
    window.addEventListener('resize', onResize);

    cleanupArticlePage = () => {
      cleanupCopyLink();
      window.removeEventListener('scroll', updateTOCSidebar);
      window.removeEventListener('resize', onResize);
      clearTimeout(resizeTimer);
    };
  }

  function initArticlePage() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setup, { once: true });
    } else {
      setup();
    }
  }

  // Run immediately on first load and after every Astro View Transition swap.
  document.addEventListener('astro:page-load', setup);
  initArticlePage();

  // Clean up all listeners before the page swaps out.
  document.addEventListener('astro:before-swap', () => cleanupArticlePage());
</script>
