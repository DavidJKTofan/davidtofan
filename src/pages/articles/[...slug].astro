---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';

export async function getStaticPaths() {
  // Only generate pages for non-draft articles
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content, headings } = await render(article);

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(article.data.date);

// Calculate reading time (rough estimate: 200 words per minute)
const wordCount = article.body?.split(/\s+/).length || 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Use article's image if set, otherwise use featured.png from article folder
const articleImage = article.data.image || `/articles/${article.id}/featured.png`;
---

<BaseLayout
  title={article.data.title}
  description={article.data.description}
  type="article"
  publishedTime={article.data.date}
  tags={article.data.tags}
  image={articleImage}
>
  <ReadingProgress />
  <ScrollToTop />

  <!-- Fixed TOC sidebar for large screens -->
  <aside 
    class="hidden lg:block fixed top-24 z-30 w-56 xl:w-64"
    style="right: max(2rem, calc((100vw - 72rem) / 2 - 16rem));"
    aria-label="Table of contents"
  >
    <div class="max-h-[calc(100vh-8rem)] overflow-y-auto pr-4 scrollbar-hide">
      <TableOfContents headings={headings} />
    </div>
  </aside>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16 lg:mr-64 xl:mr-72">
      <!-- Main content -->
      <div class="min-w-0">
        <!-- Back link -->
        <a
          href="/articles"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-surface-500 dark:text-surface-400 hover:text-accent-600 dark:hover:text-accent-400 transition-colors mb-8 group"
        >
          <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7" />
          </svg>
          Back to articles
        </a>

        <!-- Article header -->
        <header class="mb-10">
          <!-- Tags -->
          {article.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-4">
              {article.data.tags.slice(0, 4).map((tag: string) => (
                <span class="tag tag-accent text-xs">
                  {tag}
                </span>
              ))}
            </div>
          )}

          <!-- Title -->
          <h1 class="font-display font-bold text-3xl sm:text-4xl md:text-5xl text-surface-900 dark:text-surface-100 leading-tight mb-6 text-balance">
            {article.data.title}
          </h1>

          <!-- Meta info -->
          <div class="flex flex-wrap items-center gap-4 text-surface-500 dark:text-surface-400">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-gradient-to-br from-accent-400 to-accent-600 flex items-center justify-center">
                <span class="text-white text-xs font-bold">DT</span>
              </div>
              <span class="font-medium text-surface-700 dark:text-surface-300">David Tofan</span>
            </div>
            
            <span class="w-1 h-1 rounded-full bg-surface-300 dark:bg-surface-600"></span>
            
            <time datetime={article.data.date.toISOString()} class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="4" width="18" height="18" rx="2" />
                <path d="M16 2v4M8 2v4M3 10h18" />
              </svg>
              {formattedDate}
            </time>

            <span class="w-1 h-1 rounded-full bg-surface-300 dark:bg-surface-600"></span>

            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10" />
                <path d="M12 6v6l4 2" />
              </svg>
              {readingTime} min read
            </span>
          </div>
        </header>

        <!-- Article content -->
        <!-- prose = 16px base, prose-lg = 18px on sm+ screens for better readability -->
        <article class="prose prose-base sm:prose-lg dark:prose-invert max-w-none">
          <Content />
        </article>

        <!-- Article footer -->
        <footer class="mt-12 pt-8 border-t border-surface-200 dark:border-surface-800">
          <!-- Tags -->
          {article.data.tags.length > 0 && (
            <div class="mb-8">
              <h3 class="text-sm font-semibold text-surface-700 dark:text-surface-300 uppercase tracking-wide mb-3">
                Topics
              </h3>
              <div class="flex flex-wrap gap-2">
                {article.data.tags.map((tag: string) => (
                  <a
                    href={`/articles?tag=${encodeURIComponent(tag)}`}
                    class="tag hover:tag-accent"
                  >
                    {tag}
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Share -->
          <div>
            <h3 class="text-sm font-semibold text-surface-700 dark:text-surface-300 uppercase tracking-wide mb-3">
              Share this article
            </h3>
            <div class="flex items-center gap-2">
              <a
                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(article.data.title)}&url=${encodeURIComponent(Astro.url.href)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-ghost p-2"
                aria-label="Share on Twitter"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                </svg>
              </a>
              <a
                href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(Astro.url.href)}&title=${encodeURIComponent(article.data.title)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-ghost p-2"
                aria-label="Share on LinkedIn"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
              </a>
              <button
                class="btn-ghost p-2"
                aria-label="Copy link"
                id="copy-link-btn"
                data-url={Astro.url.href}
              >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                </svg>
              </button>
            </div>
          </div>
        </footer>
      </div>
  </div>
</BaseLayout>

<script>
  function setupCopyLink() {
    const copyBtn = document.getElementById('copy-link-btn');
    if (!copyBtn) return;

    copyBtn.addEventListener('click', async () => {
      const url = (copyBtn as HTMLElement).dataset.url;
      if (!url) return;

      try {
        await navigator.clipboard.writeText(url);
        
        // Show feedback
        const originalHTML = copyBtn.innerHTML;
        copyBtn.innerHTML = `
          <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M5 13l4 4L19 7" />
          </svg>
        `;
        
        setTimeout(() => {
          copyBtn.innerHTML = originalHTML;
        }, 2000);
      } catch (err) {
        console.error('Failed to copy:', err);
      }
    });
  }

  document.addEventListener('astro:page-load', setupCopyLink);
  setupCopyLink();
</script>
