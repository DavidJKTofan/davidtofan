---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import logo from '../assets/img/logo.svg';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist or has been moved."
  noIndex={true}
>
  <div class="min-h-[70vh] flex items-center justify-center px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full text-center">
      <!-- Logo -->
      <div class="mb-8 flex justify-center">
        <div class="relative">
          <div class="absolute inset-0 blur-2xl bg-accent-500/20 dark:bg-accent-400/10 rounded-full scale-150"></div>
          <Image
            src={logo}
            alt="David Tofan"
            width={80}
            height={80}
            class="relative w-20 h-20 opacity-60 dark:opacity-40"
          />
        </div>
      </div>

      <!-- 404 Number -->
      <div class="relative mb-6">
        <span class="text-[10rem] sm:text-[12rem] font-display font-bold leading-none text-surface-100 dark:text-surface-900 select-none">
          404
        </span>
        <span class="absolute inset-0 flex items-center justify-center text-[10rem] sm:text-[12rem] font-display font-bold leading-none bg-gradient-to-br from-accent-500 to-accent-600 bg-clip-text text-transparent opacity-80">
          404
        </span>
      </div>

      <!-- Message -->
      <h1 class="font-display font-bold text-2xl sm:text-3xl text-surface-900 dark:text-surface-100 mb-3">
        Page not found
      </h1>
      <p class="text-surface-600 dark:text-surface-400 mb-8 text-lg">
        The page you're looking for doesn't exist or has been moved.
      </p>

      <!-- Actions -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/" class="btn-primary w-full sm:w-auto">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Go home
        </a>
        <button
          onclick="history.back()"
          class="btn-secondary w-full sm:w-auto"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Go back
        </button>
      </div>

      <!-- Helpful Links -->
      <div class="mt-12 pt-8 border-t border-surface-200 dark:border-surface-800">
        <p class="text-sm text-surface-500 dark:text-surface-500 mb-4">
          Maybe you were looking for:
        </p>
        <div class="flex flex-wrap justify-center gap-4 text-sm">
          <a href="/articles" class="text-accent-600 dark:text-accent-400 hover:underline">
            Articles
          </a>
          <a href="/projects" class="text-accent-600 dark:text-accent-400 hover:underline">
            Projects
          </a>
          <a href="/certificates" class="text-accent-600 dark:text-accent-400 hover:underline">
            Certificates
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
