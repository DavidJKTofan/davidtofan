---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

// Get all projects (non-draft)
const projects = await getCollection('projects', ({ data }) => !data.draft);

// Sort by featured first, then by date
const sortedProjects = projects.sort((a, b) => {
  if (a.data.featured !== b.data.featured) {
    return a.data.featured ? -1 : 1;
  }
  return b.data.date.valueOf() - a.data.date.valueOf();
});

// Group by status
const activeProjects = sortedProjects.filter((p) => p.data.status === 'active');
const completedProjects = sortedProjects.filter((p) => p.data.status === 'completed');
const archivedProjects = sortedProjects.filter((p) => p.data.status === 'archived');
---

<BaseLayout
  title="Projects"
  description="Side projects, open source contributions, and experiments by David Tofan."
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <!-- Page Header -->
    <div class="max-w-2xl mb-12">
      <h1 class="font-display font-bold text-3xl sm:text-4xl md:text-5xl text-surface-900 dark:text-surface-100 mb-4">
        Projects
      </h1>
      <p class="text-lg text-surface-600 dark:text-surface-400">
        A collection of side projects, tools, and experiments I've built. Some are actively maintained, others are archived for reference.
      </p>
    </div>

    <!-- Active Projects -->
    {activeProjects.length > 0 && (
      <section class="mb-16">
        <div class="flex items-center gap-2 mb-6">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse-subtle"></span>
          <h2 class="text-lg font-semibold text-surface-800 dark:text-surface-200">
            Active Projects
          </h2>
          <span class="text-surface-400 font-normal text-sm">
            ({activeProjects.length})
          </span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {activeProjects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              slug={project.id}
              website={project.data.website}
              github={project.data.github}
              tags={project.data.tags}
              status={project.data.status}
              featured={project.data.featured}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Completed Projects -->
    {completedProjects.length > 0 && (
      <section class="mb-16">
        <div class="flex items-center gap-2 mb-6">
          <span class="w-2 h-2 rounded-full bg-blue-500"></span>
          <h2 class="text-lg font-semibold text-surface-800 dark:text-surface-200">
            Completed Projects
          </h2>
          <span class="text-surface-400 font-normal text-sm">
            ({completedProjects.length})
          </span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {completedProjects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              slug={project.id}
              website={project.data.website}
              github={project.data.github}
              tags={project.data.tags}
              status={project.data.status}
              featured={project.data.featured}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Archived Projects -->
    {archivedProjects.length > 0 && (
      <section>
        <div class="flex items-center gap-2 mb-6">
          <span class="w-2 h-2 rounded-full bg-surface-400"></span>
          <h2 class="text-lg font-semibold text-surface-800 dark:text-surface-200">
            Archived
          </h2>
          <span class="text-surface-400 font-normal text-sm">
            ({archivedProjects.length})
          </span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {archivedProjects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              slug={project.id}
              website={project.data.website}
              github={project.data.github}
              tags={project.data.tags}
              status={project.data.status}
              featured={project.data.featured}
            />
          ))}
        </div>
      </section>
    )}

    <!-- CTA -->
    <div class="mt-16 p-8 rounded-2xl bg-gradient-to-br from-surface-100 to-surface-50 dark:from-surface-800 dark:to-surface-900 border border-surface-200 dark:border-surface-700 text-center">
      <h3 class="font-display font-semibold text-xl text-surface-900 dark:text-surface-100 mb-2">
        Have an idea for a project?
      </h3>
      <p class="text-surface-600 dark:text-surface-400 mb-6 max-w-md mx-auto">
        I'm always open to collaborating on interesting projects. Let's build something together.
      </p>
      <a
        href="https://github.com/DavidJKTofan"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
        </svg>
        View on GitHub
      </a>
    </div>
  </div>
</BaseLayout>
