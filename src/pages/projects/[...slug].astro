---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
}).format(project.data.date);

const statusColors = {
  active: 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 border-green-200 dark:border-green-800',
  completed: 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 border-blue-200 dark:border-blue-800',
  archived: 'bg-surface-100 dark:bg-surface-800 text-surface-600 dark:text-surface-400 border-surface-200 dark:border-surface-700',
};
---

<BaseLayout
  title={project.data.title}
  description={project.data.description}
  image={project.data.image}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <!-- Back link -->
    <a
      href="/projects"
      class="inline-flex items-center gap-1.5 text-sm font-medium text-surface-500 dark:text-surface-400 hover:text-accent-600 dark:hover:text-accent-400 transition-colors mb-8 group"
    >
      <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7" />
      </svg>
      Back to projects
    </a>

    <!-- Project header -->
    <header class="mb-10">
      <!-- Status and meta -->
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class={`inline-flex items-center px-3 py-1 rounded-full text-sm font-medium border ${statusColors[project.data.status]}`}>
          {project.data.status === 'active' && (
            <span class="w-1.5 h-1.5 rounded-full bg-green-500 mr-2 animate-pulse-subtle"></span>
          )}
          {project.data.status.charAt(0).toUpperCase() + project.data.status.slice(1)}
        </span>
        {project.data.featured && (
          <span class="tag tag-accent">Featured</span>
        )}
      </div>

      <!-- Title -->
      <h1 class="font-display font-bold text-3xl sm:text-4xl md:text-5xl text-surface-900 dark:text-surface-100 leading-tight mb-4 text-balance">
        {project.data.title}
      </h1>

      <!-- Description -->
      <p class="text-lg text-surface-600 dark:text-surface-400 mb-6">
        {project.data.description}
      </p>

      <!-- Meta info -->
      <div class="flex flex-wrap items-center gap-4 text-surface-500 dark:text-surface-400 text-sm">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="4" width="18" height="18" rx="2" />
            <path d="M16 2v4M8 2v4M3 10h18" />
          </svg>
          Started {formattedDate}
        </span>
      </div>

      <!-- Action buttons -->
      <div class="flex flex-wrap items-center gap-3 mt-6">
        {project.data.website && (
          <a
            href={project.data.website}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            Visit Website
          </a>
        )}
        {project.data.github && (
          <a
            href={project.data.github}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
            View Source
          </a>
        )}
      </div>
    </header>

    <!-- Project content -->
    <article class="prose prose-lg dark:prose-invert max-w-none">
      <Content />
    </article>

    <!-- Tags footer -->
    {project.data.tags.length > 0 && (
      <footer class="mt-12 pt-8 border-t border-surface-200 dark:border-surface-800">
        <h3 class="text-sm font-semibold text-surface-700 dark:text-surface-300 uppercase tracking-wide mb-3">
          Technologies & Topics
        </h3>
        <div class="flex flex-wrap gap-2">
          {project.data.tags.map((tag: string) => (
            <span class="tag">
              {tag}
            </span>
          ))}
        </div>
      </footer>
    )}
  </div>
</BaseLayout>
